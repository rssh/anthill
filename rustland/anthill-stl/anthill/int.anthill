-- Rust binding for anthill.prelude.Int. Proposal 038 — host-specific
-- spec satisfaction lives separately from the language-agnostic spec
-- in stdlib/anthill/prelude/int.anthill.
namespace anthill.prelude
  provides Int language rust
    artifact "rustland/anthill-stl/src/prelude/int.rs"
    carrier { Int: "i64" }
    fact Eq[T = Int]
    fact Ordered[T = Int]
    fact Numeric[T = Int]
  end
end
