fact WorkItem(
  id: "WI-001",
  description: "Add 'end' keyword after operation expression bodies. Needed for block-style let (no 'in' keyword) to delimit where the body ends. Consistent with sort/namespace which also use 'end'. Update grammar.js, converter, and tests.",
  acceptance: [ToolPasses("cargo-test")],
  depends_on: [],
  status: Open)

