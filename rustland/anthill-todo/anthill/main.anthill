-- anthill-todo: structured work-item management.
--
-- The anthill side of the rust+anthill realization (proposal 029).
-- The companion Rust shim at src/main.rs embeds these .anthill files
-- via include_str!, builds a KB, registers stdlib builtins +
-- persistence handlers + a project-local FileStore, then calls
-- `anthill.todo.Main.main(args)` and forwards its `Int` return as the
-- process exit code.
namespace anthill.todo
  import anthill.cli.Main
  import anthill.persistence.filesystem.{FileStore}
  import anthill.persistence.{Store}
  import anthill.persistence.Store.{persist, flush}
  import anthill.prelude.{Cell}
  import anthill.prelude.Meta.{Meta}
  import anthill.prelude.Time.{now, Clock}
  import anthill.stage0.{Feedback, WorkItem, ToolPasses, AcceptanceCriterion}
  import anthill.stage0.WorkStatus.{Open}
  import anthill.prelude.{List, LogicalStream, Map, Unit}
  import anthill.prelude.Map.{empty, put, get, contains}
  import anthill.prelude.Bool.{not}
  import anthill.prelude.String.{length, substring, toUpper}
  import anthill.prelude.Console.{console, println, eprintln,
                                  ConsoleOutput, ConsoleError}
  import anthill.cli.parse.{parse_argv, ParseResult, ParsedArgs,
                            parse_ok, parse_err,
                            no_subcommand, unknown_subcommand}
  import anthill.cli.spec.{OperationSpec, ParamSpec, ParamKind}
  import anthill.cli.spec.ParamKind.{positional, flag, bool_flag}
  import anthill.cli.parse.{Binding}
  import anthill.prelude.Option.{Option, none, some}
  import anthill.prelude.Pair.{Pair, pair}
  import anthill.prelude.Ordered.{lt}
  import anthill.prelude.Eq.{eq}
  import anthill.prelude.LogicalStream.{splitFirst}
  import anthill.prelude.Int.{to_string}
  import anthill.prelude.String.{concat}
  import anthill.prelude.List.{cons, nil}
  import anthill.reflect.{KB, Term, Substitution, LogicalQuery, FactId,
                          term_functor_name, term_field, term_as_string,
                          fresh_var, make_fn, find_fact, replace_named_arg}
  import anthill.persistence.Store.{retract}
  import anthill.stage0.WorkStatus.{Claimed, Delivered, Verified}
  import anthill.reflect.KB.{kb, execute, facts_of}
  import anthill.reflect.LogicalQuery.{sort_query, pattern_query}
  import anthill.reflect.{Substitution}
  import anthill.todo.store.{WorkItemStore}
  export Main, specs

  -- The 16-subcommand registry, mirroring the legacy Rust binary's
  -- TodoCommand enum. Specs carry no params yet — per-subcommand flag
  -- and positional shapes are added alongside each operation body as
  -- it gets ported.
  operation specs() -> List[OperationSpec] =
    [ spec_named("init",              "Initialize a new anthill-todo project")
    , spec_add()
    , spec_named("status",            "Show work item counts by status")
    , spec_list()
    , spec_next()
    , spec_with_id("show",            "Show details of a work item")
    , spec_with_id("claim",           "Claim a work item")
    , spec_with_id("deliver",         "Mark a work item as delivered")
    , spec_with_id("verify",          "Mark a delivered work item as verified")
    , spec_feedback()
    , spec_with_id("delete",          "Delete a work item")
    , spec_named("update",            "Update fields of a work item")
    , spec_named("add-dependency",    "Add a dependency to a work item")
    , spec_named("remove-dependency", "Remove a dependency from a work item")
    , spec_named("graph",             "Show dependency graph")
    , spec_named("skill",             "Print Claude Code skill definition")
    ]

  operation spec_named(name: String, description: String) -> OperationSpec =
    OperationSpec(
      name: name,
      description: description,
      params: nil(),
      parent: none())

  -- Spec for subcommands taking a single required positional `id`. Used
  -- for show/claim/deliver/verify/delete and friends.
  operation spec_with_id(name: String, description: String) -> OperationSpec =
    OperationSpec(
      name: name,
      description: description,
      params: cons(
        ParamSpec(
          name: "id",
          kind: positional(),
          required: true,
          description: "Work item id (e.g. WI-009)"),
        nil()),
      parent: none())

  -- `add <description>` creates a new Open WorkItem. --depends and
  -- --acceptance are repeatable; absent --acceptance defaults to
  -- ToolPasses("cargo-test").
  operation spec_add() -> OperationSpec =
    OperationSpec(
      name: "add",
      description: "Add a new work item",
      params: cons(
        ParamSpec(
          name: "description",
          kind: positional(),
          required: true,
          description: "Description of the work item"),
        cons(
          ParamSpec(
            name: "depends",
            kind: flag(),
            required: false,
            description: "Dependency work item id (repeatable)"),
          cons(
            ParamSpec(
              name: "acceptance",
              kind: flag(),
              required: false,
              description: "Acceptance tool name (repeatable, default: cargo-test)"),
            nil()))),
      parent: none())

  -- `feedback <id> <text>` records a Feedback fact against a work
  -- item. Both positionals are required.
  operation spec_feedback() -> OperationSpec =
    OperationSpec(
      name: "feedback",
      description: "Add feedback to a work item",
      params: cons(
        ParamSpec(
          name: "id",
          kind: positional(),
          required: true,
          description: "Work item id (e.g. WI-009)"),
        cons(
          ParamSpec(
            name: "text",
            kind: positional(),
            required: true,
            description: "Feedback content"),
          nil())),
      parent: none())

  -- `next` accepts --all (show every claimable item rather than just
  -- the head of the list).
  operation spec_next() -> OperationSpec =
    OperationSpec(
      name: "next",
      description: "Show next claimable work item",
      params: cons(
        ParamSpec(
          name: "all",
          kind: bool_flag(),
          required: false,
          description: "Show all claimable items"),
        nil()),
      parent: none())

  -- `list` accepts --status <name> and --all.
  operation spec_list() -> OperationSpec =
    OperationSpec(
      name: "list",
      description: "List work items",
      params: cons(
        ParamSpec(
          name: "status",
          kind: flag(),
          required: false,
          description: "Filter by status (Open, Claimed, Delivered, Verified, ...)"),
        cons(
          ParamSpec(
            name: "all",
            kind: bool_flag(),
            required: false,
            description: "Include delivered/verified items"),
          nil())),
      parent: none())

  -- Per-WorkItem row precomputed for `cmd_list`. Walking a term's named
  -- args via `term_field` is O(arity); rolling once into Row avoids
  -- repeating that walk inside the dependent-count and sort comparators.
  entity Row(
    id: String,
    status: String,
    description: String,
    depends: List[T = String],
    unblocks: Int,
    has_feedback: Bool)

  sort Main
    sort State = ?
    requires anthill.cli.Main
    requires WorkItemStore[State]

    -- main takes the host-provided store handle, the WorkItemStore
    -- state cell (Cell[State], polymorphic over the impl), and the
    -- global --agent flag in addition to argv. Read-only commands
    -- (status / show / list / graph / next / skill) ignore store +
    -- agent; mutating commands (feedback / claim / deliver / verify /
    -- update / add / delete / add-dependency / remove-dependency)
    -- thread them through to stamp `at:` fields with the canonical
    -- YYYY-MM-DDTHH:MM:SSZ format. cmd_X bodies dispatch through the
    -- requires WorkItemStore[State] clause — the host picks the impl
    -- at call time via call_with_requirements (WI-236).
    operation main(args: List[String], store: FileStore,
                   wis_cell: Cell[State], agent: String) -> Int
      effects {ConsoleOutput, ConsoleError, Modify[store], Error, Clock}
    =
      match parse_argv(specs(), args)
        case parse_err(no_subcommand()) ->
          let _ = eprintln(console(),
            "anthill-todo: no subcommand. Try `anthill-todo skill` for usage.")
          1
        case parse_err(unknown_subcommand(_)) ->
          let _ = eprintln(console(), "anthill-todo: unknown subcommand")
          2
        case parse_err(_) ->
          let _ = eprintln(console(), "anthill-todo: argument error")
          2
        case parse_ok(ParsedArgs(name, bindings)) ->
          dispatch(name, bindings, store, agent, wis_cell)

    -- Each subcommand reads its own positional/flag bindings; the
    -- OperationSpec for each subcommand declares the params it expects
    -- (see `spec_with_id` for the canonical "needs an id" shape).
    -- `s: Cell[State]` is the WorkItemStore state cell threaded through
    -- to every cmd_X; bodies dispatch through the sort-level
    -- `requires WorkItemStore[State]` and call
    -- WorkItemStore.{lookup, by_status_of, next_id, commit, forget}
    -- on it. The host picks the impl (e.g. FileBasedWorkitemStore) by
    -- calling Main.main via call_with_requirements (WI-236).
    operation dispatch(name: String, bindings: List[Binding],
                       store: FileStore, agent: String,
                       s: Cell[State]) -> Int
      effects {ConsoleOutput, ConsoleError, Modify[store], Error, Clock}
    =
      if eq(name, "skill") then cmd_skill()
      else if eq(name, "status") then cmd_status(s)
      else if eq(name, "show") then cmd_show(bindings, s)
      else if eq(name, "list") then cmd_list(bindings, s)
      else if eq(name, "graph") then cmd_graph(s)
      else if eq(name, "next") then cmd_next(bindings, s)
      else if eq(name, "feedback") then cmd_feedback(bindings, store, agent, s)
      else if eq(name, "add") then cmd_add(bindings, store, s)
      else if eq(name, "claim") then cmd_claim(bindings, store, agent, s)
      else if eq(name, "deliver") then cmd_deliver(bindings, store, agent, s)
      else if eq(name, "verify") then cmd_verify(bindings, store, s)
      else if eq(name, "delete") then cmd_delete(bindings, store, s)
      else not_yet(name)

    -- Find the first Binding with the given name; none() otherwise.
    operation get_binding(bindings: List[Binding], name: String) -> Option[T = String] =
      match bindings
        case nil() -> none()
        case cons(b, rest) ->
          match b
            case Binding(bname, bvalue) ->
              if eq(bname, name) then some(bvalue)
              else get_binding(rest, name)

    operation not_yet(name: String) -> Int
      effects ConsoleError
    =
      let _ = eprintln(console(), "anthill-todo: subcommand not yet ported to anthill")
      let _ = eprintln(console(), name)
      2

    -- Walk a List[Term] of WorkItem facts and tally per-status counts.
    -- We don't have Map yet; use a List[Pair[String, Int]] as the bucket
    -- store (linear scan, fine for ~5 distinct statuses).

    -- True for facts that look like real WorkItem rows. The synthetic
    -- entity declaration the loader emits for `entity WorkItem(...)` has
    -- no `id: "WI-NNN"` string literal, so legacy collect_workitems
    -- skipped it; mirror that filter here.
    operation has_id(t: Term) -> Bool =
      match term_field(t, "id")
        case some(id_term) ->
          match term_as_string(id_term)
            case some(_) -> true
            case none() -> false
        case none() -> false

    operation status_of(t: Term) -> String =
      match term_field(t, "status")
        case some(field_term) ->
          match term_functor_name(field_term)
            case some(name) -> name
            case none() -> "?"
        case none() -> "?"

    -- Bump the count for `status` in `acc`, appending a new entry if
    -- absent. Returns the rebuilt list (immutable).
    operation bump(acc: List[Pair[String, Int]], status: String)
      -> List[Pair[String, Int]]
    =
      match acc
        case nil() -> cons(pair(status, 1), nil())
        case cons(p, rest) ->
          match p
            case pair(k, n) ->
              if eq(k, status) then cons(pair(k, n + 1), rest)
              else cons(p, bump(rest, status))

    operation tally(items: List[Term],
                    acc: List[Pair[String, Int]])
      -> List[Pair[String, Int]]
    =
      match items
        case nil() -> acc
        case cons(t, rest) ->
          if has_id(t) then tally(rest, bump(acc, status_of(t)))
          else tally(rest, acc)

    operation count_items(items: List[Term]) -> Int =
      match items
        case nil() -> 0
        case cons(t, rest) ->
          if has_id(t) then 1 + count_items(rest)
          else count_items(rest)

    -- Insertion sort by string key (ascending). Acceptable for ~5 buckets;
    -- swap for List.sort once that lands in stdlib.
    operation insert_sorted(buckets: List[Pair[String, Int]],
                            entry: Pair[String, Int])
      -> List[Pair[String, Int]]
    =
      match buckets
        case nil() -> cons(entry, nil())
        case cons(head, rest) ->
          match head
            case pair(hk, _) ->
              match entry
                case pair(ek, _) ->
                  if lt(ek, hk) then cons(entry, cons(head, rest))
                  else cons(head, insert_sorted(rest, entry))

    operation sort_buckets(buckets: List[Pair[String, Int]])
      -> List[Pair[String, Int]]
    =
      match buckets
        case nil() -> nil()
        case cons(head, rest) -> insert_sorted(sort_buckets(rest), head)

    operation print_counts(buckets: List[Pair[String, Int]]) -> Int
      effects ConsoleOutput
    =
      match buckets
        case nil() -> 0
        case cons(p, rest) ->
          match p
            case pair(k, n) ->
              let _ = println(console(),
                              concat("  ",
                                concat(k, concat(": ", to_string(n)))))
              print_counts(rest)

    -- Phase 2 first byte-faithful read-only command. Mirrors the legacy
    -- `run_status` shape: total count line, then per-status breakdown
    -- ordered alphabetically by status name.
    operation cmd_status(s: Cell[State]) -> Int
      effects ConsoleOutput
    =
      let items = facts_of(kb(), "WorkItem")
      let total = count_items(items)
      if eq(total, 0) then
        let _ = println(console(), "No work items found.")
        0
      else
        let _ = println(console(),
                        concat(to_string(total), " work item(s):"))
        let buckets = sort_buckets(tally(items, nil()))
        print_counts(buckets)

    -- Filter a list of WorkItem terms to the one whose id field equals
    -- the target string. Returns none() if missing.
    operation find_by_id(items: List[Term], id: String) -> Option[T = Term] =
      match items
        case nil() -> none()
        case cons(t, rest) ->
          match term_field(t, "id")
            case some(id_term) ->
              match term_as_string(id_term)
                case some(id_str) ->
                  if eq(id_str, id) then some(t)
                  else find_by_id(rest, id)
                case none() -> find_by_id(rest, id)
            case none() -> find_by_id(rest, id)

    -- Walk a `cons(string, ...)`-encoded list and build "a, b, c".
    -- Used for the `Depends on:` line.
    operation join_strings_inner(items: List[String], sep: String) -> String =
      match items
        case nil() -> ""
        case cons(s, rest) -> concat(sep, concat(s, join_strings_inner(rest, sep)))

    operation join_strings(items: List[String], sep: String) -> String =
      match items
        case nil() -> ""
        case cons(s, rest) -> concat(s, join_strings_inner(rest, sep))

    -- Drill `t.depends_on` into a List[String]; treat absence as empty.
    -- The on-disk representation is `depends_on: ["WI-N", "WI-M"]` —
    -- a List[String] literal that materializes as `cons(string, ...)`
    -- in the KB.
    operation deps_strings(t: Term) -> List[String] =
      match term_field(t, "depends_on")
        case some(_) -> deps_walk(t)
        case none() -> nil()

    -- Walk the depends_on cons-chain, extracting each head as a String.
    operation deps_walk(t: Term) -> List[String] =
      match term_field(t, "depends_on")
        case some(list_term) -> deps_walk_list(list_term)
        case none() -> nil()

    operation deps_walk_list(list_term: Term) -> List[String] =
      match term_functor_name(list_term)
        case some(fname) ->
          if eq(fname, "cons") then
            match term_field(list_term, "head")
              case some(h) ->
                match term_as_string(h)
                  case some(s) ->
                    match term_field(list_term, "tail")
                      case some(rest) -> cons(s, deps_walk_list(rest))
                      case none() -> cons(s, nil())
                  case none() -> nil()
              case none() -> nil()
          else nil()
        case none() -> nil()

    operation print_description(wi: Term) -> Unit
      effects ConsoleOutput
    =
      match term_field(wi, "description")
        case some(d) ->
          match term_as_string(d)
            case some(s) -> println(console(), concat("Description: ", s))
            case none() -> ()
        case none() -> ()

    operation print_status_line(wi: Term) -> Unit
      effects ConsoleOutput
    =
      match term_field(wi, "status")
        case some(s) ->
          match term_functor_name(s)
            case some(name) -> println(console(), concat("Status:      ", name))
            case none() -> ()
        case none() -> ()

    operation print_deps(wi: Term) -> Unit
      effects ConsoleOutput
    =
      let deps = deps_walk(wi)
      match deps
        case nil() -> ()
        case cons(_, _) ->
          println(console(),
                  concat("Depends on:  ", join_strings(deps, ", ")))

    -- Find a single workitem by id, then print id / description / status /
    -- depends_on. Acceptance criteria + Feedback rendering needs TermPrinter
    -- and cross-fact iteration; deferred to follow-up.
    operation cmd_show(bindings: List[Binding], s: Cell[State]) -> Int
      effects {ConsoleOutput, ConsoleError}
    =
      match get_binding(bindings, "id")
        case none() ->
          let _ = eprintln(console(), "error: missing work item id")
          2
        case some(id) ->
          let items = facts_of(kb(), "WorkItem")
          match find_by_id(items, id)
            case none() ->
              let _ = eprintln(console(),
                               concat("error: work item '",
                                      concat(id, "' not found")))
              1
            case some(wi) ->
              let _ = println(console(), concat("ID:          ", id))
              let _ = print_description(wi)
              let _ = print_status_line(wi)
              let _ = print_deps(wi)
              0

    -- ── cmd_list helpers ──────────────────────────────────────────

    -- Lift a WorkItem term into the precomputed Row shape. Skips items
    -- whose `id` field isn't a string (the synthetic entity-declaration
    -- fact). `unblocks` and `has_feedback` are filled in a second pass
    -- once the full row list is available — initialize to 0 and false.
    operation row_of(t: Term) -> Option[T = Row] =
      match term_field(t, "id")
        case some(id_term) ->
          match term_as_string(id_term)
            case some(id_str) ->
              let st = status_of(t)
              let desc = match term_field(t, "description")
                case some(d) ->
                  match term_as_string(d)
                    case some(s) -> s
                    case none() -> ""
                case none() -> ""
              let deps = deps_walk(t)
              some(Row(
                id: id_str,
                status: st,
                description: desc,
                depends: deps,
                unblocks: 0,
                has_feedback: false))
            case none() -> none()
        case none() -> none()

    operation rows_of(items: List[Term]) -> List[Row] =
      match items
        case nil() -> nil()
        case cons(t, rest) ->
          match row_of(t)
            case some(r) -> cons(r, rows_of(rest))
            case none() -> rows_of(rest)

    -- Default visibility: hide Delivered/Verified.
    operation is_closed(status: String) -> Bool =
      if eq(status, "Delivered") then true
      else if eq(status, "Verified") then true
      else false

    -- Status filter match. The legacy CLI uses eq_ignore_ascii_case;
    -- emulate via a "Capitalize first letter, lowercase rest" pass so
    -- "open" / "OPEN" / "Open" all match WorkStatus names that begin
    -- with a single uppercase letter.
    operation matches_filter(status: String, filter: String) -> Bool =
      if eq(status, filter) then true
      else if eq(status, capitalized(filter)) then true
      else false

    -- Capitalize "open" → "Open". toUpper is a builtin (String.toUpper).
    operation capitalized(s: String) -> String =
      if eq(length(s), 0) then s
      else concat(toUpper(substring(s, 0, 1)),
                  substring(s, 1, length(s)))

    operation filter_rows(rows: List[Row],
                          status_filter: Option[T = String],
                          show_all: Bool)
      -> List[Row]
    =
      match rows
        case nil() -> nil()
        case cons(r, rest) ->
          match r
            case Row(_, status, _, _, _, _) ->
              if keep(status, status_filter, show_all) then
                cons(r, filter_rows(rest, status_filter, show_all))
              else filter_rows(rest, status_filter, show_all)

    operation keep(status: String,
                   status_filter: Option[T = String],
                   show_all: Bool)
      -> Bool
    =
      match status_filter
        case some(f) -> matches_filter(status, f)
        case none() ->
          if show_all then true
          else not(is_closed(status))

    -- Build a Map[id → Row] once so per-row lookups (status_for,
    -- any_unmet) become O(1) instead of O(N). Map.put copies the
    -- backing indexmap each call (O(N)), so build cost is O(N²);
    -- but every downstream lookup pays O(1), so over a partition pass
    -- (N rows × D deps) this drops the total from O(N²·D) to O(N²+N·D).
    -- WI-183.
    operation build_row_map(rows: List[Row]) -> Map[K = String, V = Row] =
      build_row_map_acc(rows, empty())

    operation build_row_map_acc(rows: List[Row], acc: Map[K = String, V = Row])
      -> Map[K = String, V = Row]
    =
      match rows
        case nil() -> acc
        case cons(r, rest) ->
          match r
            case Row(rid, _, _, _, _, _) ->
              -- First-wins: legacy linear scan via status_for returns
              -- the first matching row, so duplicate ids (data permits
              -- them) keep the original entry. Map.put would overwrite.
              if contains(acc, rid) then build_row_map_acc(rest, acc)
              else build_row_map_acc(rest, put(acc, rid, r))

    -- Status lookup via the prebuilt row map.
    operation status_for_m(row_map: Map[K = String, V = Row], id: String)
      -> Option[T = String]
    =
      match get(row_map, id)
        case none() -> none()
        case some(r) ->
          match r
            case Row(_, status, _, _, _, _) -> some(status)

    operation is_satisfied(status: String) -> Bool =
      if eq(status, "Delivered") then true
      else if eq(status, "Verified") then true
      else false

    operation any_unmet(deps: List[String], row_map: Map[K = String, V = Row]) -> Bool =
      match deps
        case nil() -> false
        case cons(dep, rest) ->
          match status_for_m(row_map, dep)
            case some(s) ->
              if is_satisfied(s) then any_unmet(rest, row_map)
              else true
            case none() -> true  -- unknown dep counts as unmet

    -- ── Dependents map: id → list of items depending on it ────────

    -- Build a Map[id → List[dependent_id]] in one pass. For each row's
    -- depends_on list, register the row's id under each dependency.
    -- Replaces the legacy List[Pair[String, String]] flat-pairs
    -- representation: dependents lookup goes from O(E) per call to
    -- O(1). WI-183.
    operation build_dep_map(rows: List[Row])
      -> Map[K = String, V = List[T = String]]
    =
      build_dep_map_acc(rows, empty())

    operation build_dep_map_acc(rows: List[Row],
                                acc: Map[K = String, V = List[T = String]])
      -> Map[K = String, V = List[T = String]]
    =
      match rows
        case nil() -> acc
        case cons(r, rest) ->
          match r
            case Row(rid, _, _, deps, _, _) ->
              build_dep_map_acc(rest, register_dependents(acc, deps, rid))

    -- For each `dep` in `deps`, append `rid` to dep's existing
    -- dependents list. Append (vs prepend) preserves the same
    -- caller-order legacy `direct_dependents` produced — important
    -- so cmd_graph's tree walk emits siblings in source order.
    operation register_dependents(m: Map[K = String, V = List[T = String]],
                                   deps: List[String],
                                   rid: String)
      -> Map[K = String, V = List[T = String]]
    =
      match deps
        case nil() -> m
        case cons(d, rest) ->
          let prior = match get(m, d)
            case some(existing) -> existing
            case none() -> nil()
          register_dependents(put(m, d, append_string(prior, rid)), rest, rid)

    operation append_string(xs: List[String], x: String) -> List[String] =
      match xs
        case nil() -> cons(x, nil())
        case cons(h, rest) -> cons(h, append_string(rest, x))

    -- Direct dependents of `id` via the prebuilt map.
    operation direct_dependents_m(dep_map: Map[K = String, V = List[T = String]],
                                   id: String)
      -> List[String]
    =
      match get(dep_map, id)
        case some(deps) -> deps
        case none() -> nil()

    -- Visited set as a sorted-list of ids. `visited_contains` does a
    -- linear scan; for the depth we expect, that's fine.
    operation visited_contains(visited: List[String], id: String) -> Bool =
      match visited
        case nil() -> false
        case cons(h, rest) ->
          if eq(h, id) then true else visited_contains(rest, id)

    -- Recursive transitive-dependents count. Tracks a per-call visited
    -- set to enforce *unique* reachable counting — a diamond dep
    -- pattern (X → A → D and X → B → D) must count D once, not twice.
    -- (We tried global memoization across rows; the count of a node is
    -- not a sum-able quantity in shared-path graphs, so per-call
    -- visited is the right shape.)
    --
    -- For the per-row pass (`fill_unblocks`) this is O(N) per row × N
    -- rows = O(N^2). The user's "topo-sort" idea would amortize
    -- further, but the correct topo recurrence isn't sum-of-children
    -- counts — it's union-of-children's-reachable-sets, which needs
    -- set arithmetic. Leaving that as a perf follow-up; correctness
    -- comes first.

    operation count_transitive(id: String,
                               dep_map: Map[K = String, V = List[T = String]],
                               visited: List[String])
      -> Pair[Int, List[String]]
    =
      if visited_contains(visited, id) then pair(0, visited)
      else
        let visited2 = cons(id, visited)
        let direct = direct_dependents_m(dep_map, id)
        count_transitive_walk(direct, dep_map, visited2)

    operation count_transitive_walk(deps: List[String],
                                    dep_map: Map[K = String, V = List[T = String]],
                                    visited: List[String])
      -> Pair[Int, List[String]]
    =
      match deps
        case nil() -> pair(0, visited)
        case cons(d, rest) ->
          match count_transitive(d, dep_map, visited)
            case pair(sub, v2) ->
              match count_transitive_walk(rest, dep_map, v2)
                case pair(more, v3) -> pair(1 + sub + more, v3)

    -- ── Feedback set ──────────────────────────────────────────────

    -- Membership-set of work-item ids that have at least one Feedback
    -- fact, used for the [has feedback] annotation. Map[id → true]
    -- gives O(1) `Map.contains` instead of an O(F) linear scan per row
    -- on a List[String]. WI-183.
    operation feedback_set() -> Map[K = String, V = Bool] =
      let fb_facts = facts_of(kb(), "Feedback")
      collect_feedback_set(fb_facts, empty())

    operation collect_feedback_set(facts: List[Term],
                                    acc: Map[K = String, V = Bool])
      -> Map[K = String, V = Bool]
    =
      match facts
        case nil() -> acc
        case cons(t, rest) ->
          match term_field(t, "workitem")
            case some(wi_term) ->
              match term_as_string(wi_term)
                case some(wi_id) ->
                  collect_feedback_set(rest, put(acc, wi_id, true))
                case none() -> collect_feedback_set(rest, acc)
            case none() -> collect_feedback_set(rest, acc)

    -- ── Annotate rows with has_feedback only ───────────────────────
    -- `unblocks` is filled in later for the (much smaller) ready
    -- partition; computing it here for every row is O(N^3) in the
    -- interpreter (each count_transitive walks up to N dependents and
    -- annotate_rows fires N times).

    operation annotate_rows(rows: List[Row],
                            fb_set: Map[K = String, V = Bool])
      -> List[Row]
    =
      match rows
        case nil() -> nil()
        case cons(r, rest) ->
          match r
            case Row(rid, status, desc, deps, _, _) ->
              cons(
                Row(
                  id: rid,
                  status: status,
                  description: desc,
                  depends: deps,
                  unblocks: 0,
                  has_feedback: contains(fb_set, rid)),
                annotate_rows(rest, fb_set))

    -- Fill in `unblocks` for the supplied rows. Each row's count uses a
    -- fresh visited set (correctness for diamond patterns); we call
    -- this only on the `ready` partition to keep the cost bounded.
    operation fill_unblocks(rows: List[Row],
                            dep_map: Map[K = String, V = List[T = String]])
      -> List[Row]
    =
      match rows
        case nil() -> nil()
        case cons(r, rest) ->
          match r
            case Row(rid, status, desc, deps, _, fb) ->
              match count_transitive(rid, dep_map, nil())
                case pair(n, _) ->
                  cons(
                    Row(
                      id: rid,
                      status: status,
                      description: desc,
                      depends: deps,
                      unblocks: n,
                      has_feedback: fb),
                    fill_unblocks(rest, dep_map))

    -- ── Sorting ───────────────────────────────────────────────────

    -- Order key for "ready": (unblocks desc, id asc). Returns true when
    -- `a` should come before `b`.
    operation ready_lt(a: Row, b: Row) -> Bool =
      match a
        case Row(aid, _, _, _, ac, _) ->
          match b
            case Row(bid, _, _, _, bc, _) ->
              if eq(ac, bc) then lt(aid, bid)
              else if lt(ac, bc) then false  -- larger count first
              else true

    operation insert_ready(rs: List[Row], r: Row) -> List[Row] =
      match rs
        case nil() -> cons(r, nil())
        case cons(h, rest) ->
          if ready_lt(r, h) then cons(r, cons(h, rest))
          else cons(h, insert_ready(rest, r))

    operation sort_ready(rs: List[Row]) -> List[Row] =
      sort_ready_loop(rs, nil())

    operation sort_ready_loop(rs: List[Row], acc: List[Row]) -> List[Row] =
      match rs
        case nil() -> acc
        case cons(h, rest) -> sort_ready_loop(rest, insert_ready(acc, h))

    -- Stable insertion sort by id. We process the input list with an
    -- accumulator that already holds the prefix in sorted order; new
    -- elements get appended after any equal-key entries, preserving
    -- original encounter order for duplicates (legacy Rust slice::sort_by
    -- is stable, so ties retain input order — the data has duplicate
    -- WI-169 ids and the bundle must match that ordering).
    operation insert_by_id(rs: List[Row], r: Row) -> List[Row] =
      match rs
        case nil() -> cons(r, nil())
        case cons(h, rest) ->
          match r
            case Row(rid, _, _, _, _, _) ->
              match h
                case Row(hid, _, _, _, _, _) ->
                  if lt(rid, hid) then cons(r, cons(h, rest))
                  else cons(h, insert_by_id(rest, r))

    -- Left-fold variant — preserves original order on ties because we
    -- iterate input left-to-right and `insert_by_id` only places
    -- strictly-less-than items before the head.
    operation sort_by_id(rs: List[Row]) -> List[Row] =
      sort_by_id_loop(rs, nil())

    operation sort_by_id_loop(rs: List[Row], acc: List[Row]) -> List[Row] =
      match rs
        case nil() -> acc
        case cons(h, rest) -> sort_by_id_loop(rest, insert_by_id(acc, h))

    -- ── Partition into ready / blocked ────────────────────────────

    operation partition_ready(rows: List[Row],
                               row_map: Map[K = String, V = Row])
      -> List[Row]
    =
      match rows
        case nil() -> nil()
        case cons(r, rest) ->
          match r
            case Row(_, _, _, deps, _, _) ->
              if any_unmet(deps, row_map) then partition_ready(rest, row_map)
              else cons(r, partition_ready(rest, row_map))

    operation partition_blocked(rows: List[Row],
                                 row_map: Map[K = String, V = Row])
      -> List[Row]
    =
      match rows
        case nil() -> nil()
        case cons(r, rest) ->
          match r
            case Row(_, _, _, deps, _, _) ->
              if any_unmet(deps, row_map) then cons(r, partition_blocked(rest, row_map))
              else partition_blocked(rest, row_map)

    -- ── Print ─────────────────────────────────────────────────────

    operation deps_suffix(deps: List[String]) -> String =
      match deps
        case nil() -> ""
        case cons(_, _) ->
          concat(" (depends: ", concat(join_strings(deps, ", "), ")"))

    operation unblocks_suffix(n: Int) -> String =
      if eq(n, 0) then ""
      else concat(" [unblocks ", concat(to_string(n), "]"))

    operation feedback_suffix(b: Bool) -> String =
      if b then " [has feedback]" else ""

    operation render_ready(r: Row) -> String =
      match r
        case Row(id, status, desc, deps, n, fb) ->
          concat("  ",
            concat(id, concat(" [", concat(status, concat("] ",
              concat(desc,
                concat(deps_suffix(deps),
                  concat(unblocks_suffix(n), feedback_suffix(fb))))))) ))

    operation render_blocked(r: Row) -> String =
      match r
        case Row(id, status, desc, deps, _, fb) ->
          concat("  ",
            concat(id, concat(" [", concat(status, concat("] ",
              concat(desc, concat(deps_suffix(deps), feedback_suffix(fb))))))))

    operation print_rows_ready(rs: List[Row]) -> Unit
      effects ConsoleOutput
    =
      match rs
        case nil() -> ()
        case cons(r, rest) ->
          let _ = println(console(), render_ready(r))
          print_rows_ready(rest)

    operation print_rows_blocked(rs: List[Row]) -> Unit
      effects ConsoleOutput
    =
      match rs
        case nil() -> ()
        case cons(r, rest) ->
          let _ = println(console(), render_blocked(r))
          print_rows_blocked(rest)

    operation count_rows(rs: List[Row]) -> Int =
      match rs
        case nil() -> 0
        case cons(_, rest) -> 1 + count_rows(rest)

    -- ── cmd_list itself ───────────────────────────────────────────

    operation cmd_list(bindings: List[Binding], s: Cell[State]) -> Int
      effects ConsoleOutput
    =
      let status_filter = get_binding(bindings, "status")
      let show_all = match get_binding(bindings, "all")
        case some(_) -> true
        case none() -> false
      let raw_rows = rows_of(facts_of(kb(), "WorkItem"))
      let dep_map = build_dep_map(raw_rows)
      let fb_set = feedback_set()
      let annotated = annotate_rows(raw_rows, fb_set)
      let row_map = build_row_map(annotated)
      let filtered = filter_rows(annotated, status_filter, show_all)
      if eq(count_rows(filtered), 0) then
        let _ = println(console(), "No work items found.")
        0
      else
        -- Compute `unblocks` only for the (smaller) ready slice; the
        -- blocked slice doesn't display the count.
        let ready_unfilled = partition_ready(filtered, row_map)
        let ready = sort_ready(fill_unblocks(ready_unfilled, dep_map))
        let blocked = sort_by_id(partition_blocked(filtered, row_map))
        let _ = print_rows_ready(ready)
        let _ = match blocked
          case nil() -> ()
          case cons(_, _) ->
            let _ = match ready
              case nil() -> ()
              case cons(_, _) -> println(console(), "")
            let _ = println(console(), "  -- blocked --")
            print_rows_blocked(blocked)
        let _ = println(console(),
                        concat(to_string(count_rows(filtered)), " item(s)"))
        0

    -- ── cmd_graph ─────────────────────────────────────────────────

    -- Find rows whose depends_on list is empty (roots of the dependents
    -- tree — no precondition).
    operation find_roots(rows: List[Row]) -> List[Row] =
      match rows
        case nil() -> nil()
        case cons(r, rest) ->
          match r
            case Row(_, _, _, deps, _, _) ->
              match deps
                case nil() -> cons(r, find_roots(rest))
                case cons(_, _) -> find_roots(rest)

    operation status_or_unknown(row_map: Map[K = String, V = Row], id: String) -> String =
      match status_for_m(row_map, id)
        case some(s) -> s
        case none() -> "?"

    -- Print one node and recurse into its direct dependents. Mirrors
    -- legacy `print_tree` exactly: connector is "" at the root, "├─ "
    -- for non-last siblings, "└─ " for last; child_prefix continues
    -- with "│  " or "   " depending on whether `is_last` was true.
    operation print_tree(id: String,
                         is_root: Bool,
                         is_last: Bool,
                         prefix: String,
                         row_map: Map[K = String, V = Row],
                         dep_map: Map[K = String, V = List[T = String]])
      -> Unit
      effects ConsoleOutput
    =
      let connector =
        if is_root then ""
        else if is_last then "└─ "
        else "├─ "
      let status = status_or_unknown(row_map, id)
      let _ = println(console(),
                      concat(prefix,
                        concat(connector,
                          concat(id, concat(" [", concat(status, "]"))))))
      let child_prefix =
        if is_root then "   "
        else if is_last then concat(prefix, "   ")
        else concat(prefix, "│  ")
      let children = direct_dependents_m(dep_map, id)
      print_children(children, child_prefix, row_map, dep_map)

    operation print_children(children: List[String],
                             prefix: String,
                             row_map: Map[K = String, V = Row],
                             dep_map: Map[K = String, V = List[T = String]])
      -> Unit
      effects ConsoleOutput
    =
      match children
        case nil() -> ()
        case cons(c, rest) ->
          let last = match rest
            case nil() -> true
            case cons(_, _) -> false
          let _ = print_tree(c, false, last, prefix, row_map, dep_map)
          print_children(rest, prefix, row_map, dep_map)

    operation print_roots(roots: List[Row],
                          row_map: Map[K = String, V = Row],
                          dep_map: Map[K = String, V = List[T = String]])
      -> Unit
      effects ConsoleOutput
    =
      match roots
        case nil() -> ()
        case cons(r, rest) ->
          match r
            case Row(rid, _, _, _, _, _) ->
              let _ = print_tree(rid, true, true, "", row_map, dep_map)
              print_roots(rest, row_map, dep_map)

    operation cmd_graph(s: Cell[State]) -> Int
      effects ConsoleOutput
    =
      let raw_rows = rows_of(facts_of(kb(), "WorkItem"))
      if eq(count_rows(raw_rows), 0) then
        let _ = println(console(), "No work items found.")
        0
      else
        let dep_map = build_dep_map(raw_rows)
        let row_map = build_row_map(raw_rows)
        let roots = find_roots(raw_rows)
        let _ = print_roots(roots, row_map, dep_map)
        0

    -- ── cmd_add ──────────────────────────────────────────────────
    --
    -- `add <description> [--depends ID]* [--acceptance tool]*`
    -- creates a fresh WorkItem with status Open. The next id is
    -- computed by walking existing WorkItem facts and bumping the
    -- max WI-NNN suffix. Acceptance defaults to ToolPasses("cargo-test")
    -- when no --acceptance flag is supplied.

    -- Collect every Binding whose name matches `name`, in caller order.
    -- parse_argv conses bindings front-most-recent, so the last flag the
    -- user typed appears first in the input list. Walking that list and
    -- consing into `acc` flips each time, leaving acc in caller order on
    -- exit. Used by cmd_add for repeatable flags (--depends, --acceptance).
    operation collect_all_bindings_acc(bindings: List[Binding],
                                        name: String,
                                        acc: List[String]) -> List[String] =
      match bindings
        case nil() -> acc
        case cons(b, rest) ->
          match b
            case Binding(bname, bvalue) ->
              if eq(bname, name) then
                collect_all_bindings_acc(rest, name, cons(bvalue, acc))
              else
                collect_all_bindings_acc(rest, name, acc)

    operation collect_all_bindings(bindings: List[Binding],
                                    name: String) -> List[String] =
      collect_all_bindings_acc(bindings, name, nil())

    -- Wrap each tool name as ToolPasses(tool: <name>) for the WorkItem
    -- acceptance field. Default fallback when the user supplies no
    -- --acceptance flag is a single cargo-test entry.
    operation tool_to_acceptance(tool: String) -> AcceptanceCriterion =
      ToolPasses(tool: tool)

    operation tools_to_acceptance(tools: List[String])
      -> List[AcceptanceCriterion]
    =
      match tools
        case nil() -> nil()
        case cons(h, rest) ->
          cons(tool_to_acceptance(h), tools_to_acceptance(rest))

    -- Find the largest WI-NNN suffix across the WorkItem fact set.
    -- Returns 0 for an empty project, so the first added id is WI-001.
    operation max_id_in(items: List[Term], best: Int) -> Int =
      match items
        case nil() -> best
        case cons(t, rest) ->
          let candidate = id_suffix_of(t)
          let new_best = if candidate > best then candidate else best
          max_id_in(rest, new_best)

    operation id_suffix_of(t: Term) -> Int =
      match term_field(t, "id")
        case none() -> 0
        case some(id_term) ->
          match term_as_string(id_term)
            case none() -> 0
            case some(s) -> parse_wi_suffix(s)

    -- Parse the numeric suffix of an id like "WI-186". Returns 0 on
    -- any malformed input — those WorkItems can't shift the max.
    operation parse_wi_suffix(s: String) -> Int =
      if lt(length(s), 4) then 0
      else
        if eq(substring(s, 0, 3), "WI-") then
          parse_int_or_zero(substring(s, 3, length(s)))
        else 0

    operation parse_int_or_zero(s: String) -> Int =
      parse_int_acc(s, 0, 0)

    operation parse_int_acc(s: String, idx: Int, acc: Int) -> Int =
      if eq(idx, length(s)) then acc
      else
        let d = digit_value(substring(s, idx, idx + 1))
        if lt(d, 0) then 0
        else parse_int_acc(s, idx + 1, acc * 10 + d)

    -- Map a single-char string to its decimal digit, or -1 for
    -- non-digits. Used by parse_int_acc to bail out on malformed
    -- WI-NNN suffixes.
    operation digit_value(c: String) -> Int =
      if eq(c, "0") then 0
      else if eq(c, "1") then 1
      else if eq(c, "2") then 2
      else if eq(c, "3") then 3
      else if eq(c, "4") then 4
      else if eq(c, "5") then 5
      else if eq(c, "6") then 6
      else if eq(c, "7") then 7
      else if eq(c, "8") then 8
      else if eq(c, "9") then 9
      else 0 - 1

    -- Format a non-negative Int as a 3-zero-padded decimal string.
    -- Larger numbers expand naturally (`WI-1000` is fine).
    operation pad3(n: Int) -> String =
      if lt(n, 10) then concat("00", to_string(n))
      else if lt(n, 100) then concat("0", to_string(n))
      else to_string(n)

    operation next_workitem_id() -> String =
      let items = facts_of(kb(), "WorkItem")
      concat("WI-", pad3(max_id_in(items, 0) + 1))

    operation cmd_add(bindings: List[Binding],
                      store: FileStore,
                      s: Cell[State]) -> Int
      effects {ConsoleOutput, ConsoleError, Modify[store], Error}
    =
      match get_binding(bindings, "description")
        case none() ->
          let _ = eprintln(console(), "add: missing description")
          2
        case some(description) ->
          do_add(store, description,
                 collect_all_bindings(bindings, "depends"),
                 collect_all_bindings(bindings, "acceptance"))

    operation do_add(store: FileStore, description: String,
                     depends_on: List[String],
                     raw_acceptance: List[String]) -> Int
      effects {ConsoleOutput, Modify[store], Error}
    =
      let id = next_workitem_id()
      let acceptance = match raw_acceptance
        case nil() -> tools_to_acceptance(cons("cargo-test", nil()))
        case cons(_, _) -> tools_to_acceptance(raw_acceptance)
      let fact = WorkItem(
        id: id,
        description: description,
        acceptance: acceptance,
        depends_on: depends_on,
        status: Open())
      let _ = persist(store, fact, Meta(entries: nil()))
      let _ = flush(store, nil())
      let _ = println(console(),
                      concat("added: ",
                        concat(id, concat(" — ", description))))
      0

    -- ── cmd_claim ────────────────────────────────────────────────
    --
    -- `claim <id>` transitions a WorkItem from status Open to
    -- Claimed(agent: <--agent>, since: now()). Retract+assert path:
    -- find the head term, look up its FactId, retract on the
    -- IndexedFileStore (which knows the source span), persist the
    -- replacement, flush. Skips the legacy `claimable(?id, ?desc)`
    -- gate for now — a future patch can wire the same gate cmd_next
    -- uses.

    operation cmd_claim(bindings: List[Binding],
                         store: FileStore,
                         agent: String,
                         s: Cell[State]) -> Int
      effects {ConsoleOutput, ConsoleError, Modify[store], Error, Clock}
    =
      match get_binding(bindings, "id")
        case none() ->
          let _ = eprintln(console(), "claim: missing id")
          2
        case some(id) ->
          match find_by_id(facts_of(kb(), "WorkItem"), id)
            case none() ->
              let _ = eprintln(console(),
                concat("error: work item '", concat(id, "' not found")))
              1
            case some(old_term) -> do_claim(store, agent, id, old_term)

    operation do_claim(store: FileStore, agent: String,
                       id: String, old_term: Term) -> Int
      effects {ConsoleOutput, ConsoleError, Modify[store], Error, Clock}
    =
      match find_fact(old_term)
        case none() ->
          let _ = eprintln(console(),
            "internal: WorkItem head missing from KB rule index")
          1
        case some(fid) ->
          let new_status = Claimed(agent: agent, since: now())
          let new_term = replace_named_arg(old_term, "status", new_status)
          let _ = retract(store, fid)
          let _ = persist(store, new_term, Meta(entries: nil()))
          let _ = flush(store, nil())
          let _ = println(console(),
            concat("claimed: ", concat(id, concat(" by ", agent))))
          0

    -- ── cmd_deliver ──────────────────────────────────────────────
    --
    -- `deliver <id>` transitions Claimed → Delivered(agent, at).
    -- Same retract+assert shape as cmd_claim.

    operation cmd_deliver(bindings: List[Binding],
                           store: FileStore,
                           agent: String,
                           s: Cell[State]) -> Int
      effects {ConsoleOutput, ConsoleError, Modify[store], Error, Clock}
    =
      match get_binding(bindings, "id")
        case none() ->
          let _ = eprintln(console(), "deliver: missing id")
          2
        case some(id) ->
          match find_by_id(facts_of(kb(), "WorkItem"), id)
            case none() ->
              let _ = eprintln(console(),
                concat("error: work item '", concat(id, "' not found")))
              1
            case some(old_term) -> do_deliver(store, agent, id, old_term)

    operation do_deliver(store: FileStore, agent: String,
                         id: String, old_term: Term) -> Int
      effects {ConsoleOutput, ConsoleError, Modify[store], Error, Clock}
    =
      match find_fact(old_term)
        case none() ->
          let _ = eprintln(console(),
            "internal: WorkItem head missing from KB rule index")
          1
        case some(fid) ->
          let new_term = replace_named_arg(old_term, "status",
                          Delivered(agent: agent, at: now()))
          let _ = retract(store, fid)
          let _ = persist(store, new_term, Meta(entries: nil()))
          let _ = flush(store, nil())
          let _ = println(console(),
            concat("delivered: ", concat(id, concat(" by ", agent))))
          0

    -- ── cmd_verify ───────────────────────────────────────────────
    --
    -- `verify <id>` transitions Delivered → Verified(at). No --agent
    -- — the verifier identity isn't recorded in the legacy fact shape.

    operation cmd_verify(bindings: List[Binding],
                          store: FileStore,
                          s: Cell[State]) -> Int
      effects {ConsoleOutput, ConsoleError, Modify[store], Error, Clock}
    =
      match get_binding(bindings, "id")
        case none() ->
          let _ = eprintln(console(), "verify: missing id")
          2
        case some(id) ->
          match find_by_id(facts_of(kb(), "WorkItem"), id)
            case none() ->
              let _ = eprintln(console(),
                concat("error: work item '", concat(id, "' not found")))
              1
            case some(old_term) -> do_verify(store, id, old_term)

    operation do_verify(store: FileStore, id: String, old_term: Term) -> Int
      effects {ConsoleOutput, ConsoleError, Modify[store], Error, Clock}
    =
      match find_fact(old_term)
        case none() ->
          let _ = eprintln(console(),
            "internal: WorkItem head missing from KB rule index")
          1
        case some(fid) ->
          let new_term = replace_named_arg(old_term, "status",
                          Verified(at: now()))
          let _ = retract(store, fid)
          let _ = persist(store, new_term, Meta(entries: nil()))
          let _ = flush(store, nil())
          let _ = println(console(), concat("verified: ", id))
          0

    -- ── cmd_delete ───────────────────────────────────────────────
    --
    -- `delete <id>` retracts the WorkItem fact entirely — no
    -- replacement persisted. The IndexedFileStore's source-span
    -- retract drops the fact block from disk; flush atomically
    -- rewrites the affected file.

    operation cmd_delete(bindings: List[Binding],
                          store: FileStore,
                          s: Cell[State]) -> Int
      effects {ConsoleOutput, ConsoleError, Modify[store], Error}
    =
      match get_binding(bindings, "id")
        case none() ->
          let _ = eprintln(console(), "delete: missing id")
          2
        case some(id) ->
          match find_by_id(facts_of(kb(), "WorkItem"), id)
            case none() ->
              let _ = eprintln(console(),
                concat("error: work item '", concat(id, "' not found")))
              1
            case some(old_term) -> do_delete(store, id, old_term)

    operation do_delete(store: FileStore, id: String, old_term: Term) -> Int
      effects {ConsoleOutput, ConsoleError, Modify[store], Error}
    =
      match find_fact(old_term)
        case none() ->
          let _ = eprintln(console(),
            "internal: WorkItem head missing from KB rule index")
          1
        case some(fid) ->
          let _ = retract(store, fid)
          let _ = flush(store, nil())
          let _ = println(console(), concat("deleted: ", id))
          0

    -- ── cmd_feedback ─────────────────────────────────────────────
    --
    -- `feedback <id> <text>` asserts a Feedback fact against the
    -- target work item, persists it, and flushes the store. Output
    -- mirrors legacy run_feedback's `feedback on <id>: <text>` line.
    -- Mutating commands receive `store` (the FileStore handle) and
    -- `agent` (the global --agent flag, default "user") via dispatch.
    operation cmd_feedback(bindings: List[Binding],
                            store: FileStore,
                            agent: String,
                            s: Cell[State]) -> Int
      effects {ConsoleOutput, ConsoleError, Modify[store], Error}
    =
      let id_opt = get_binding(bindings, "id")
      let text_opt = get_binding(bindings, "text")
      match id_opt
        case none() ->
          let _ = eprintln(console(), "feedback: missing id")
          2
        case some(id) ->
          match text_opt
            case none() ->
              let _ = eprintln(console(), "feedback: missing text")
              2
            case some(text) ->
              do_feedback(store, agent, id, text)

    operation do_feedback(store: FileStore, agent: String,
                          id: String, text: String) -> Int
      effects {ConsoleOutput, Modify[store], Error}
    =
      let fact = Feedback(
        workitem: id,
        author: agent,
        content: text,
        at: now())
      let _ = persist(store, fact, Meta(entries: nil()))
      let _ = flush(store, nil())
      let _ = println(console(),
                      concat("feedback on ",
                        concat(id, concat(": ", text))))
      0

    operation cmd_skill() -> Int
      effects ConsoleOutput
    =
      let _ = println(console(), "anthill-todo")
      let _ = println(console(),
        "Manage structured work items via the anthill-todo CLI.")
      let _ = println(console(), "")
      let _ = println(console(), "Subcommands: skill, init, status, list, next, show,")
      let _ = println(console(), "  add, feedback, claim, deliver, verify, update, delete,")
      let _ = println(console(), "  add-dependency, remove-dependency, graph.")
      0

    -- ── cmd_next ─────────────────────────────────────────────────
    --
    -- Show the next claimable work item: items in status Open whose
    -- dependencies are all Delivered/Verified. With --all, every such
    -- item; otherwise just the first. WI-182 unblocks this — the
    -- `fresh_var` and `make_fn` builtins let anthill code construct
    -- the goal `claimable(?id, ?desc)` and run it via `KB.execute`.

    -- Pull a String binding off a substitution by var name; return
    -- `fallback` when missing or when the bound term isn't a String
    -- literal (e.g. a synthetic entity declaration's logical-var
    -- field).
    operation extract_string_field(subst: Substitution,
                                   var_name: String,
                                   fallback: String) -> String =
      match Substitution.lookup(subst, var_name)
        case none() -> fallback
        case some(t) ->
          match term_as_string(t)
            case none() -> fallback
            case some(s) -> s

    -- Single-pass stream walk: pull one solution at a time, dedupe by id
    -- against a running `seen` accumulator, print as we go. Tail-style
    -- recursion: every recursive call is the last expression in its
    -- branch, so the deepest stack is bounded by `limit` (1000). No
    -- intermediate list — `append_pair`-style quadratic build was the
    -- cause of the stack overflow on real workitem sets.
    operation walk_solutions(stream: LogicalStream,
                              show_all: Bool,
                              limit: Int,
                              seen: List[String],
                              printed: Int) -> Int
      effects ConsoleOutput
    =
      if eq(limit, 0) then printed
      else
        match splitFirst(stream)
          case none() -> printed
          case some(p) ->
            match p
              case pair(subst, rest) ->
                let id = extract_string_field(subst, "id", "?")
                let desc = extract_string_field(subst, "desc", "")
                if list_contains_string(seen, id) then
                  walk_solutions(rest, show_all, limit + (0 - 1), seen, printed)
                else
                  let _ = println(console(),
                                  concat("  ",
                                    concat(id, concat(" — ", desc))))
                  if show_all then
                    walk_solutions(rest, show_all,
                                   limit + (0 - 1),
                                   cons(id, seen),
                                   printed + 1)
                  else
                    printed + 1

    operation list_contains_string(xs: List[String], needle: String) -> Bool =
      match xs
        case nil() -> false
        case cons(h, rest) ->
          if eq(h, needle) then true
          else list_contains_string(rest, needle)


    operation cmd_next(bindings: List[Binding], s: Cell[State]) -> Int
      effects {ConsoleOutput, ConsoleError, Error}
    =
      let show_all = match get_binding(bindings, "all")
        case some(_) -> true
        case none() -> false
      let id_var = fresh_var("id")
      let desc_var = fresh_var("desc")
      let goal = make_fn("anthill.stage0.workflow.claimable",
                         cons(id_var, cons(desc_var, nil())))
      let stream = execute(kb(), pattern_query(term: goal))
      let printed = walk_solutions(stream, show_all, 1000, nil(), 0)
      if eq(printed, 0) then
        let _ = println(console(), "No claimable items (all blocked or none open).")
        0
      else 0
  end
end
