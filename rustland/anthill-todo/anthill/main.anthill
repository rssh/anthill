-- anthill-todo: structured work-item management.
--
-- The anthill side of the rust+anthill realization (proposal 029).
-- The companion Rust shim at src/main.rs embeds these .anthill files
-- via include_str!, builds a KB, registers stdlib builtins +
-- persistence handlers + a project-local FileStore, then calls
-- `anthill.todo.Main.main(args)` and forwards its `Int64` return as the
-- process exit code.
namespace anthill.todo
  import anthill.cli.Main
  import anthill.persistence.filesystem.{FileStore}
  import anthill.persistence.{Store}
  import anthill.prelude.{Cell}
  import anthill.prelude.Meta.{Meta}
  import anthill.prelude.Time.{now, Clock}
  import anthill.stage0.{Feedback, WorkItem, ToolPasses, AcceptanceCriterion}
  import anthill.stage0.WorkStatus.{Open}
  import anthill.prelude.{List, Stream, Map, Unit}
  import anthill.prelude.Map.{empty, put, get, contains}
  import anthill.prelude.Bool.{not}
  import anthill.prelude.String.{length, substring, toUpper, toLower, padRight}
  import anthill.prelude.Console.{console, println, eprintln,
                                  ConsoleOutput, ConsoleError}
  import anthill.cli.parse.{parse_argv, ParseResult, ParsedArgs,
                            parse_ok, parse_err,
                            no_subcommand, unknown_subcommand}
  import anthill.cli.spec.{OperationSpec, ParamSpec, ParamKind}
  import anthill.cli.spec.ParamKind.{positional, flag, bool_flag}
  import anthill.cli.parse.{Binding}
  import anthill.prelude.Option.{Option, none, some}
  import anthill.prelude.Pair.{Pair, pair}
  import anthill.prelude.Ordered.{lt}
  import anthill.prelude.Eq.{eq}
  import anthill.prelude.Stream.{splitFirst}
  import anthill.prelude.Int64.{to_string}
  import anthill.prelude.String.{concat}
  import anthill.prelude.List.{cons, nil}
  import anthill.prelude.Iterable.{size}
  import anthill.reflect.{Term, Substitution, term_functor_name,
                          term_field, term_as_string,
                          fresh_var, make_fn, term_to_string,
                          term_list_items}
  import anthill.stage0.WorkStatus.{Claimed, Delivered, Verified}
  import anthill.reflect.KB.{kb, execute, facts_of}
  import anthill.reflect.LogicalQuery.{pattern_query}
  import anthill.todo.store.{WorkItemStore}
  import anthill.todo.store.WorkItemStore.{lookup, by_status_of, all,
                                           next_id, commit, replace, forget,
                                           commit_feedback, has_tag,
                                           tag_item, untag_item,
                                           items_with_tag, tags_of,
                                           raw_term_of}
  export Main, specs

  -- The 16-subcommand registry, mirroring the legacy Rust binary's
  -- TodoCommand enum. Specs carry no params yet — per-subcommand flag
  -- and positional shapes are added alongside each operation body as
  -- it gets ported.
  operation specs() -> List[OperationSpec] =
    [ spec_named("init",              "Initialize a new anthill-todo project")
    , spec_add()
    , spec_insert()
    , spec_named("status",            "Show work item counts by status")
    , spec_list()
    , spec_next()
    , spec_with_id("show",            "Show details of a work item")
    , spec_with_id("claim",           "Claim a work item")
    , spec_with_id("unclaim",         "Release a claimed work item back to Open")
    , spec_with_id("deliver",         "Mark a work item as delivered")
    , spec_with_id("verify",          "Mark a delivered work item as verified")
    , spec_feedback()
    , spec_with_id("delete",          "Delete a work item")
    , spec_update()
    , spec_dep_change("add-dependency",    "Add a dependency to a work item")
    , spec_dep_change("remove-dependency", "Remove a dependency from a work item")
    , spec_tag_change("tag",          "Add a work item to a named list")
    , spec_tag_change("untag",        "Remove a work item from a named list")
    , spec_named("graph",             "Show dependency graph")
    , spec_named("skill",             "Print Claude Code skill definition")
    ]

  operation spec_named(name: String, description: String) -> OperationSpec =
    OperationSpec(
      name: name,
      description: description,
      params: nil(),
      parent: none())

  -- Spec for subcommands taking a single required positional `id`. Used
  -- for show/claim/deliver/verify/delete and friends.
  operation spec_with_id(name: String, description: String) -> OperationSpec =
    OperationSpec(
      name: name,
      description: description,
      params: cons(
        ParamSpec(
          name: "id",
          kind: positional(),
          required: true,
          description: "Work item id (e.g. WI-009)"),
        nil()),
      parent: none())

  -- `add-dependency / remove-dependency <id> <dep>` take two
  -- positionals: the work item id and the dependency target id.
  operation spec_dep_change(name: String, description: String) -> OperationSpec =
    OperationSpec(
      name: name,
      description: description,
      params: cons(
        ParamSpec(
          name: "id",
          kind: positional(),
          required: true,
          description: "Work item id (e.g. WI-009)"),
        cons(
          ParamSpec(
            name: "dep",
            kind: positional(),
            required: true,
            description: "Dependency work item id"),
          nil())),
      parent: none())

  -- `tag / untag <id> <name>` take two positionals: the work item id
  -- and the tag (named-list) name.
  operation spec_tag_change(name: String, description: String) -> OperationSpec =
    OperationSpec(
      name: name,
      description: description,
      params: cons(
        ParamSpec(
          name: "id",
          kind: positional(),
          required: true,
          description: "Work item id (e.g. WI-009)"),
        cons(
          ParamSpec(
            name: "name",
            kind: positional(),
            required: true,
            description: "Tag name (e.g. typing)"),
          nil())),
      parent: none())

  -- `update <id> [--description X] [--acceptance Y]` updates a work
  -- item's description and/or acceptance criteria. --acceptance is
  -- repeatable; passing the flag at least once replaces the entire
  -- acceptance list (cannot append a single tool — that's by design,
  -- matching the legacy run_update).
  operation spec_update() -> OperationSpec =
    OperationSpec(
      name: "update",
      description: "Update fields of a work item",
      params: cons(
        ParamSpec(
          name: "id",
          kind: positional(),
          required: true,
          description: "Work item id (e.g. WI-009)"),
        cons(
          ParamSpec(
            name: "description",
            kind: flag(),
            required: false,
            description: "New description"),
          cons(
            ParamSpec(
              name: "acceptance",
              kind: flag(),
              required: false,
              description: "Acceptance tool name (repeatable, replaces all)"),
            nil()))),
      parent: none())

  -- `add <description>` creates a new Open WorkItem. --depends and
  -- --acceptance are repeatable; absent --acceptance defaults to
  -- ToolPasses("cargo-test").
  operation spec_add() -> OperationSpec =
    OperationSpec(
      name: "add",
      description: "Add a new work item",
      params: cons(
        ParamSpec(
          name: "description",
          kind: positional(),
          required: true,
          description: "Description of the work item"),
        cons(
          ParamSpec(
            name: "depends",
            kind: flag(),
            required: false,
            description: "Dependency work item id (repeatable)"),
          cons(
            ParamSpec(
              name: "acceptance",
              kind: flag(),
              required: false,
              description: "Acceptance tool name (repeatable, default: cargo-test)"),
            cons(
              ParamSpec(
                name: "tag",
                kind: flag(),
                required: false,
                description: "Named list to tag the new item with (repeatable)"),
              nil())))),
      parent: none())

  -- `insert <description> --before <id>`: create a new work item, tag it,
  -- and make <id> depend on it — placing the new item earlier in any
  -- dependency-ordered sequence (the build loop's "insert prerequisite").
  operation spec_insert() -> OperationSpec =
    OperationSpec(
      name: "insert",
      description: "Add a new work item before an existing one in a sequence",
      params: cons(
        ParamSpec(
          name: "description",
          kind: positional(),
          required: true,
          description: "Description of the new work item"),
        cons(
          ParamSpec(
            name: "before",
            kind: flag(),
            required: true,
            description: "Existing work item the new one is inserted before"),
          cons(
            ParamSpec(
              name: "tag",
              kind: flag(),
              required: false,
              description: "Named list to tag the new item with (repeatable)"),
            cons(
              ParamSpec(
                name: "depends",
                kind: flag(),
                required: false,
                description: "Dependency work item id (repeatable)"),
              cons(
                ParamSpec(
                  name: "acceptance",
                  kind: flag(),
                  required: false,
                  description: "Acceptance tool name (repeatable)"),
                nil()))))),
      parent: none())

  -- `feedback <id> <text>` records a Feedback fact against a work
  -- item. Both positionals are required.
  operation spec_feedback() -> OperationSpec =
    OperationSpec(
      name: "feedback",
      description: "Add feedback to a work item",
      params: cons(
        ParamSpec(
          name: "id",
          kind: positional(),
          required: true,
          description: "Work item id (e.g. WI-009)"),
        cons(
          ParamSpec(
            name: "text",
            kind: positional(),
            required: true,
            description: "Feedback content"),
          nil())),
      parent: none())

  -- `next` accepts --all (show every claimable item rather than just
  -- the head of the list).
  operation spec_next() -> OperationSpec =
    OperationSpec(
      name: "next",
      description: "Show next claimable work item",
      params: cons(
        ParamSpec(
          name: "all",
          kind: bool_flag(),
          required: false,
          description: "Show all claimable items"),
        nil()),
      parent: none())

  -- `list` accepts --status <name> and --all.
  operation spec_list() -> OperationSpec =
    OperationSpec(
      name: "list",
      description: "List work items",
      params: cons(
        ParamSpec(
          name: "status",
          kind: flag(),
          required: false,
          description: "Filter by status (Open, Claimed, Delivered, Verified, ...)"),
        cons(
          ParamSpec(
            name: "all",
            kind: bool_flag(),
            required: false,
            description: "Include delivered/verified items"),
          cons(
            ParamSpec(
              name: "tag",
              kind: flag(),
              required: false,
              description: "Show a named list in dependency (sequence) order"),
            nil()))),
      parent: none())

  -- Per-WorkItem row precomputed for `cmd_list`. Walking a term's named
  -- args via `term_field` is O(arity); rolling once into Row avoids
  -- repeating that walk inside the dependent-count and sort comparators.
  entity Row(
    id: String,
    status: String,
    description: String,
    depends: List[String],
    unblocks: Int64,
    has_feedback: Bool)

  sort Main
    sort State = ?
    requires anthill.cli.Main
    requires WorkItemStore[State]

    -- main takes the host-provided store handle, the WorkItemStore
    -- state cell (Cell[State], polymorphic over the impl), and the
    -- global --agent flag in addition to argv. Read-only commands
    -- (status / show / list / graph / next / skill) ignore store +
    -- agent; mutating commands (feedback / claim / deliver / verify /
    -- update / add / delete / add-dependency / remove-dependency)
    -- thread them through to stamp `at:` fields with the canonical
    -- YYYY-MM-DDTHH:MM:SSZ format. cmd_X bodies dispatch through the
    -- requires WorkItemStore[State] clause — the host picks the impl
    -- at call time via call_with_requirements (WI-236).
    operation main(args: List[String], store: FileStore,
                   wis_cell: Cell[State], agent: String) -> Int64
      effects {ConsoleOutput, ConsoleError, Modify[store], Modify[wis_cell],
               Error, Clock}
    =
      match parse_argv(specs(), args)
        case parse_err(no_subcommand()) ->
          let _ = eprintln(console(),
            "anthill-todo: no subcommand. Try `anthill-todo --help` for usage.")
          1
        case parse_err(unknown_subcommand(given)) ->
          if eq(given, "--help") then print_help(specs())
          else if eq(given, "-h") then print_help(specs())
          else if eq(given, "help") then print_help(specs())
          else
            let _ = eprintln(console(),
              concat("anthill-todo: unknown subcommand '",
                concat(given, "'. Try `anthill-todo --help`.")))
            2
        case parse_err(_) ->
          let _ = eprintln(console(), "anthill-todo: argument error")
          2
        case parse_ok(ParsedArgs(name, args)) ->
          dispatch(name, args, store, agent, wis_cell)

    -- Each subcommand reads its own positional/flag args; the
    -- OperationSpec for each subcommand declares the params it expects
    -- (see `spec_with_id` for the canonical "needs an id" shape).
    -- `s: Cell[State]` is the WorkItemStore state cell threaded through
    -- to every cmd_X; bodies dispatch through the sort-level
    -- `requires WorkItemStore[State]` and call
    -- WorkItemStore.{lookup, by_status_of, next_id, commit, replace, forget}
    -- on it. The host picks the impl (e.g. FileBasedWorkitemStore) by
    -- calling Main.main via call_with_requirements (WI-236).
    operation dispatch(name: String, args: List[Binding],
                       store: FileStore, agent: String,
                       s: Cell[State]) -> Int64
      effects {ConsoleOutput, ConsoleError, Modify[store], Modify[s],
               Error, Clock}
    =
      -- `skill` and `init` are intercepted host-side (static doc print /
      -- pre-KB scaffolding); their specs stay in the catalogue for --help.
      if eq(name, "status") then cmd_status(s)
      else if eq(name, "show") then cmd_show(args, s)
      else if eq(name, "list") then cmd_list(args, s)
      else if eq(name, "graph") then cmd_graph(s)
      else if eq(name, "next") then cmd_next(args, s)
      else if eq(name, "feedback") then cmd_feedback(args, store, agent, s)
      else if eq(name, "add") then cmd_add(args, store, s)
      else if eq(name, "claim") then cmd_claim(args, store, agent, s)
      else if eq(name, "unclaim") then cmd_unclaim(args, store, agent, s)
      else if eq(name, "deliver") then cmd_deliver(args, store, agent, s)
      else if eq(name, "verify") then cmd_verify(args, store, s)
      else if eq(name, "delete") then cmd_delete(args, store, s)
      else if eq(name, "update") then cmd_update(args, store, s)
      else if eq(name, "add-dependency") then
        cmd_add_dependency(args, store, s)
      else if eq(name, "remove-dependency") then
        cmd_remove_dependency(args, store, s)
      else if eq(name, "tag") then cmd_tag(args, s)
      else if eq(name, "untag") then cmd_untag(args, s)
      else if eq(name, "insert") then cmd_insert(args, s)
      else not_yet(name)

    -- `tag <id> <name>` — attach a named-list tag to a work item.
    -- Validation order mirrors the legacy run_tag: non-empty name,
    -- item exists, not already tagged. (The legacy require_tag_entity
    -- gate is structural here: the bundle imports Tag from stage0.)
    operation cmd_tag(args: List[Binding], s: Cell[State]) -> Int64
      effects {ConsoleOutput, ConsoleError, Modify[s], Error}
    =
      match get_arg(args, "id")
        case none() ->
          let _ = eprintln(console(), "tag: missing id")
          2
        case some(id) ->
          match get_arg(args, "name")
            case none() ->
              let _ = eprintln(console(), "tag: missing name")
              2
            case some(name) ->
              if eq(name, "") then
                let _ = eprintln(console(), "error: tag name must be non-empty")
                1
              else
                match WorkItemStore.lookup(s, id)
                  case none() ->
                    let _ = eprintln(console(),
                      concat("error: work item '", concat(id, "' not found")))
                    1
                  case some(_) ->
                    if WorkItemStore.has_tag(s, id, name) then
                      let _ = eprintln(console(),
                        concat("error: '",
                          concat(id, concat("' is already tagged '",
                            concat(name, "'")))))
                      1
                    else
                      let _ = WorkItemStore.tag_item(s, id, name)
                      let _ = println(console(),
                        concat("tagged: ", concat(id, concat(" +", name))))
                      0

    -- `untag <id> <name>` — detach a tag. Mirrors the legacy run_untag:
    -- the only validation is that the tag exists.
    operation cmd_untag(args: List[Binding], s: Cell[State]) -> Int64
      effects {ConsoleOutput, ConsoleError, Modify[s], Error}
    =
      match get_arg(args, "id")
        case none() ->
          let _ = eprintln(console(), "untag: missing id")
          2
        case some(id) ->
          match get_arg(args, "name")
            case none() ->
              let _ = eprintln(console(), "untag: missing name")
              2
            case some(name) ->
              if WorkItemStore.has_tag(s, id, name) then
                let _ = WorkItemStore.untag_item(s, id, name)
                let _ = println(console(),
                  concat("untagged: ", concat(id, concat(" -", name))))
                0
              else
                let _ = eprintln(console(),
                  concat("error: '",
                    concat(id, concat("' is not tagged '",
                      concat(name, "'")))))
                1

    -- Find the first Binding with the given name; none() otherwise
    -- (the stdlib `Iterable.find` via the WI-443 identifier-receiver dot
    -- form + unwrap to the binding's value).
    operation get_arg(args: List[Binding], name: String) -> Option[String] =
      match args.find(lambda b ->
          match b
            case Binding(bname, _) -> eq(bname, name))
        case none() -> none()
        case some(Binding(_, bvalue)) -> some(bvalue)

    operation not_yet(name: String) -> Int64
      effects ConsoleError
    =
      let _ = eprintln(console(), "anthill-todo: subcommand not yet ported to anthill")
      let _ = eprintln(console(), name)
      2

    -- `--help` / `-h` / `help`: spec-driven command summary (the
    -- OperationSpec catalogue is the single source of truth, so this can
    -- never drift from the actual dispatch the way a hand-written help
    -- text would).
    operation print_help(ss: List[OperationSpec]) -> Int64
      effects ConsoleOutput
    =
      let _ = println(console(), "Structured work management powered by anthill")
      let _ = println(console(), "")
      let _ = println(console(),
        "Usage: anthill-todo [-d <DIR>] [--agent <NAME>] <COMMAND> [ARGS]")
      let _ = println(console(), "")
      let _ = println(console(), "Commands:")
      let _ = print_help_lines(ss)
      0

    operation print_help_lines(ss: List[OperationSpec]) -> Unit
      effects ConsoleOutput
    =
      match ss
        case nil() -> ()
        case cons(sp, rest) ->
          let _ = match sp
            case OperationSpec(name, description, _, _) ->
              println(console(),
                concat("  ", concat(padRight(name, 20), description)))
          print_help_lines(rest)

    -- Bump the count for `status` in `acc`, appending a new entry
    -- if absent. Returns the rebuilt list (immutable).
    operation bump(acc: List[Pair[String, Int64]], status: String)
      -> List[Pair[String, Int64]]
    =
      match acc
        case nil() -> cons(pair(status, 1), nil())
        case cons(p, rest) ->
          match p
            case pair(k, n) ->
              if eq(k, status) then cons(pair(k, n + 1), rest)
              else cons(p, bump(rest, status))

    -- Insertion sort by string key (ascending). Acceptable for ~5 buckets;
    -- swap for List.sort once that lands in stdlib.
    operation insert_sorted(buckets: List[Pair[String, Int64]],
                            entry: Pair[String, Int64])
      -> List[Pair[String, Int64]]
    =
      match buckets
        case nil() -> cons(entry, nil())
        case cons(head, rest) ->
          match head
            case pair(hk, _) ->
              match entry
                case pair(ek, _) ->
                  if lt(ek, hk) then cons(entry, cons(head, rest))
                  else cons(head, insert_sorted(rest, entry))

    operation sort_buckets(buckets: List[Pair[String, Int64]])
      -> List[Pair[String, Int64]]
    =
      match buckets
        case nil() -> nil()
        case cons(head, rest) -> insert_sorted(sort_buckets(rest), head)

    operation print_counts(buckets: List[Pair[String, Int64]]) -> Int64
      effects ConsoleOutput
    =
      match buckets
        case nil() -> 0
        case cons(p, rest) ->
          match p
            case pair(k, n) ->
              let _ = println(console(),
                              concat("  ",
                                concat(k, concat(": ", to_string(n)))))
              print_counts(rest)

    -- Status field's functor short name, or "?" when the field isn't
    -- a recognizable Entity/Ref.
    operation status_name_w(w: WorkItem) -> String =
      match w
        case WorkItem(_, _, _, _, _, _, _, st) ->
          match term_functor_name(st)
            case some(name) -> name
            case none() -> "?"

    operation tally_w(items: List[WorkItem],
                      acc: List[Pair[String, Int64]])
      -> List[Pair[String, Int64]]
    =
      match items
        case nil() -> acc
        case cons(w, rest) ->
          tally_w(rest, bump(acc, status_name_w(w)))

    -- Total count line, then per-status breakdown ordered alphabetically
    -- by status name. Mirrors the legacy `run_status` output shape.
    operation cmd_status(s: Cell[State]) -> Int64
      effects {ConsoleOutput, Error}
    =
      let items = WorkItemStore.all(s)
      let total = size(items)
      if eq(total, 0) then
        let _ = println(console(), "No work items found.")
        0
      else
        let _ = println(console(),
                        concat(to_string(total), " work item(s):"))
        let buckets = sort_buckets(tally_w(items, nil()))
        print_counts(buckets)

    -- Walk a `cons(string, ...)`-encoded list and build "a, b, c".
    -- Used for the `Depends on:` line.
    operation join_strings_inner(items: List[String], sep: String) -> String =
      match items
        case nil() -> ""
        case cons(s, rest) -> concat(sep, concat(s, join_strings_inner(rest, sep)))

    operation join_strings(items: List[String], sep: String) -> String =
      match items
        case nil() -> ""
        case cons(s, rest) -> concat(s, join_strings_inner(rest, sep))

    -- Extract `depends_on` from a materialized WorkItem as a List[String].
    -- WI-408: the loader's some-coercion wraps a bare on-disk value
    -- (`depends_on: [...]`) in `some(...)` at load, so the slot is always a
    -- proper Option — `none()` (absent field) or `some(list)`; the old
    -- bare-chain reflect-launder is gone.
    operation deps_of_w(w: WorkItem) -> List[String] =
      match w
        case WorkItem(_, _, _, _, deps, _, _, _) -> normalize_deps(deps)

    operation normalize_deps(d: Option[List[String]]) -> List[String] =
      match d
        case none() -> nil()
        case some(xs) -> xs

    -- Print id / description / status / depends_on for a single WorkItem.
    operation cmd_show(args: List[Binding], s: Cell[State]) -> Int64
      effects {ConsoleOutput, ConsoleError, Error}
    =
      match get_arg(args, "id")
        case none() ->
          let _ = eprintln(console(), "error: missing work item id")
          2
        case some(id) ->
          match WorkItemStore.lookup(s, id)
            case none() ->
              let _ = eprintln(console(),
                               concat("error: work item '",
                                      concat(id, "' not found")))
              1
            case some(wi) ->
              let _ = println(console(), concat("ID:          ", id))
              let _ = print_description_w(wi)
              let _ = print_status_line_w(wi)
              let _ = print_deps_w(wi)
              let _ = print_tags_w(s, id)
              let _ = print_term_section_w(s, id, "context", "Context:")
              let _ = print_term_section_w(s, id, "acceptance", "Acceptance:")
              let _ = print_feedback_w(id)
              0

    operation print_tags_w(s: Cell[State], id: String) -> Unit
      effects {ConsoleOutput, Error}
    =
      let tags = sort_strings_unique(WorkItemStore.tags_of(s, id))
      match tags
        case nil() -> ()
        case cons(_, _) ->
          println(console(),
                  concat("Tags:        ", join_strings(tags, ", ")))

    -- Print a list-valued field of the STORED fact term, one element per
    -- "  - " line in the canonical TermPrinter text — exactly what the
    -- legacy run_show rendered. Reading the raw term (not the entity)
    -- keeps the sub-term shapes verbatim.
    operation print_term_section_w(s: Cell[State], id: String,
                                   field: String, label: String) -> Unit
      effects {ConsoleOutput, Error}
    =
      match WorkItemStore.raw_term_of(s, id)
        case none() -> ()
        case some(t) ->
          match term_field(t, field)
            case none() -> ()
            case some(ft) ->
              match term_list_items(ft)
                case nil() -> ()
                case cons(h, rest) ->
                  let _ = println(console(), label)
                  print_term_lines(cons(h, rest))

    operation print_term_lines(ts: List[T = Term]) -> Unit
      effects ConsoleOutput
    =
      match ts
        case nil() -> ()
        case cons(t, rest) ->
          let _ = println(console(), concat("  - ", term_to_string(t)))
          print_term_lines(rest)

    operation print_feedback_w(id: String) -> Unit
      effects {ConsoleOutput, Error}
    =
      print_fb_items(facts_of(kb(), Feedback), id)

    operation print_fb_items(ts: List[T = Term], id: String) -> Unit
      effects ConsoleOutput
    =
      match ts
        case nil() -> ()
        case cons(t, rest) ->
          let _ = print_fb_one(t, id)
          print_fb_items(rest, id)

    operation print_fb_one(t: Term, id: String) -> Unit
      effects ConsoleOutput
    =
      match term_field(t, "workitem")
        case none() -> ()
        case some(wt) ->
          match term_as_string(wt)
            case none() -> ()
            case some(w) ->
              if eq(w, id) then
                println(console(),
                  concat("Feedback (",
                    concat(string_field_or(t, "author", "?"),
                      concat("): ", string_field_or(t, "content", "")))))
              else ()

    operation string_field_or(t: Term, field: String, default: String) -> String =
      match term_field(t, field)
        case none() -> default
        case some(ft) ->
          match term_as_string(ft)
            case none() -> default
            case some(v) -> v

    operation print_description_w(w: WorkItem) -> Unit
      effects ConsoleOutput
    =
      match w
        case WorkItem(_, description, _, _, _, _, _, _) ->
          -- WI-408: the slot is a proper Option — peel it, then read the
          -- payload Term as a String.
          match description
            case none() -> ()
            case some(t) ->
              match term_as_string(t)
                case some(s) -> println(console(), concat("Description: ", s))
                case none() -> ()

    operation print_status_line_w(w: WorkItem) -> Unit
      effects ConsoleOutput
    =
      match w
        case WorkItem(_, _, _, _, _, _, _, st) ->
          match term_functor_name(st)
            case some(name) -> println(console(), concat("Status:      ", name))
            case none() -> ()

    operation print_deps_w(w: WorkItem) -> Unit
      effects ConsoleOutput
    =
      let deps = deps_of_w(w)
      match deps
        case nil() -> ()
        case cons(_, _) ->
          println(console(),
                  concat("Depends on:  ", join_strings(deps, ", ")))

    -- ── cmd_list helpers ──────────────────────────────────────────

    -- Lift a typed WorkItem into the precomputed Row shape. The
    -- `unblocks` and `has_feedback` fields are filled in a second
    -- pass (annotate_rows / fill_unblocks).
    operation row_of_w(w: WorkItem) -> Row =
      match w
        case WorkItem(id, desc, _, _, _, _, _, _) ->
          -- WI-408: peel the Option, then read the payload Term.
          let desc_str = match desc
            case none() -> ""
            case some(t) ->
              match term_as_string(t)
                case some(s) -> s
                case none() -> ""
          Row(
            id: id,
            status: status_name_w(w),
            description: desc_str,
            depends: deps_of_w(w),
            unblocks: 0,
            has_feedback: false)

    operation rows_of_w(items: List[WorkItem]) -> List[Row] =
      match items
        case nil() -> nil()
        case cons(w, rest) -> cons(row_of_w(w), rows_of_w(rest))

    -- Default visibility: hide Delivered/Verified.
    operation is_closed(status: String) -> Bool =
      if eq(status, "Delivered") then true
      else if eq(status, "Verified") then true
      else false

    -- Status filter match — the legacy CLI's eq_ignore_ascii_case, done
    -- honestly: lowercase both sides. (The previous "Capitalize first
    -- letter" emulation claimed to match "OPEN" but didn't — capitalizing
    -- "OPEN" yields "OPEN", not "Open".)
    operation matches_filter(status: String, filter: String) -> Bool =
      eq(toLower(status), toLower(filter))

    operation filter_rows(rows: List[Row],
                          status_filter: Option[String],
                          show_all: Bool)
      -> List[Row]
    =
      match rows
        case nil() -> nil()
        case cons(r, rest) ->
          match r
            case Row(_, status, _, _, _, _) ->
              if keep(status, status_filter, show_all) then
                cons(r, filter_rows(rest, status_filter, show_all))
              else filter_rows(rest, status_filter, show_all)

    operation keep(status: String,
                   status_filter: Option[String],
                   show_all: Bool)
      -> Bool
    =
      match status_filter
        case some(f) -> matches_filter(status, f)
        case none() ->
          if show_all then true
          else not(is_closed(status))

    -- Build a Map[id → Row] once so per-row lookups (status_for,
    -- any_unmet) become O(1) instead of O(N). Map.put copies the
    -- backing indexmap each call (O(N)), so build cost is O(N²);
    -- but every downstream lookup pays O(1), so over a partition pass
    -- (N rows × D deps) this drops the total from O(N²·D) to O(N²+N·D).
    -- WI-183.
    operation build_row_map(rows: List[Row]) -> Map[String, Row] =
      build_row_map_acc(rows, empty())

    operation build_row_map_acc(rows: List[Row], acc: Map[String, Row])
      -> Map[String, Row]
    =
      match rows
        case nil() -> acc
        case cons(r, rest) ->
          match r
            case Row(rid, _, _, _, _, _) ->
              -- First-wins: legacy linear scan via status_for returns
              -- the first matching row, so duplicate ids (data permits
              -- them) keep the original entry. Map.put would overwrite.
              if contains(acc, rid) then build_row_map_acc(rest, acc)
              else build_row_map_acc(rest, put(acc, rid, r))

    -- Status lookup via the prebuilt row map.
    operation status_for_m(row_map: Map[String, Row], id: String)
      -> Option[String]
    =
      match get(row_map, id)
        case none() -> none()
        case some(r) ->
          match r
            case Row(_, status, _, _, _, _) -> some(status)

    operation is_satisfied(status: String) -> Bool =
      if eq(status, "Delivered") then true
      else if eq(status, "Verified") then true
      else false

    operation any_unmet(deps: List[String], row_map: Map[String, Row]) -> Bool =
      match deps
        case nil() -> false
        case cons(dep, rest) ->
          match status_for_m(row_map, dep)
            case some(s) ->
              if is_satisfied(s) then any_unmet(rest, row_map)
              else true
            case none() -> true  -- unknown dep counts as unmet

    -- ── Dependents map: id → list of items depending on it ────────

    -- Build a Map[id → List[dependent_id]] in one pass. For each row's
    -- depends_on list, register the row's id under each dependency.
    -- Replaces the legacy List[Pair[String, String]] flat-pairs
    -- representation: dependents lookup goes from O(E) per call to
    -- O(1). WI-183.
    operation build_dep_map(rows: List[Row])
      -> Map[String, List[String]]
    =
      build_dep_map_acc(rows, empty())

    operation build_dep_map_acc(rows: List[Row],
                                acc: Map[String, List[String]])
      -> Map[String, List[String]]
    =
      match rows
        case nil() -> acc
        case cons(r, rest) ->
          match r
            case Row(rid, _, _, deps, _, _) ->
              build_dep_map_acc(rest, register_dependents(acc, deps, rid))

    -- For each `dep` in `deps`, append `rid` to dep's existing
    -- dependents list. Append (vs prepend) preserves the same
    -- caller-order legacy `direct_dependents` produced — important
    -- so cmd_graph's tree walk emits siblings in source order.
    operation register_dependents(m: Map[String, List[String]],
                                   deps: List[String],
                                   rid: String)
      -> Map[String, List[String]]
    =
      match deps
        case nil() -> m
        case cons(d, rest) ->
          let prior = match get(m, d)
            case some(existing) -> existing
            case none() -> nil()
          register_dependents(put(m, d, append_string(prior, rid)), rest, rid)

    operation append_string(xs: List[String], x: String) -> List[String] =
      match xs
        case nil() -> cons(x, nil())
        case cons(h, rest) -> cons(h, append_string(rest, x))

    -- Direct dependents of `id` via the prebuilt map.
    operation direct_dependents_m(dep_map: Map[String, List[String]],
                                   id: String)
      -> List[String]
    =
      match get(dep_map, id)
        case some(deps) -> deps
        case none() -> nil()

    -- Recursive transitive-dependents count. Tracks a per-call visited
    -- set to enforce *unique* reachable counting — a diamond dep
    -- pattern (X → A → D and X → B → D) must count D once, not twice.
    -- (We tried global memoization across rows; the count of a node is
    -- not a sum-able quantity in shared-path graphs, so per-call
    -- visited is the right shape.)
    --
    -- The visited set is a Map[id → true]: `contains` / `put` are
    -- O(log N) on the persistent map, so one walk over M reachable
    -- nodes costs O(M log N). (A topo-sort with
    -- union-of-children's-reachable-sets would amortize the per-row
    -- repetition further, but needs set-union arithmetic; left as a
    -- follow-up.)

    operation count_transitive(id: String,
                               dep_map: Map[String, List[String]],
                               visited: Map[String, Bool])
      -> Pair[Int64, Map[String, Bool]]
    =
      if contains(visited, id) then pair(0, visited)
      else
        let visited2 = put(visited, id, true)
        let direct = direct_dependents_m(dep_map, id)
        count_transitive_walk(direct, dep_map, visited2)

    operation count_transitive_walk(deps: List[String],
                                    dep_map: Map[String, List[String]],
                                    visited: Map[String, Bool])
      -> Pair[Int64, Map[String, Bool]]
    =
      match deps
        case nil() -> pair(0, visited)
        case cons(d, rest) ->
          match count_transitive(d, dep_map, visited)
            case pair(sub, v2) ->
              match count_transitive_walk(rest, dep_map, v2)
                case pair(more, v3) -> pair(1 + sub + more, v3)

    -- ── Feedback set ──────────────────────────────────────────────

    -- Membership-set of work-item ids that have at least one Feedback
    -- fact, used for the [has feedback] annotation. Map[id → true]
    -- gives O(1) `Map.contains` instead of an O(F) linear scan per row
    -- on a List[String]. WI-183.
    operation feedback_set() -> Map[String, Bool] =
      let fb_facts = facts_of(kb(), Feedback)
      collect_feedback_set(fb_facts, empty())

    operation collect_feedback_set(facts: List[Term],
                                    acc: Map[String, Bool])
      -> Map[String, Bool]
    =
      match facts
        case nil() -> acc
        case cons(t, rest) ->
          match term_field(t, "workitem")
            case none() -> collect_feedback_set(rest, acc)
            case some(wi_term) ->
              match term_as_string(wi_term)
                case none() -> collect_feedback_set(rest, acc)
                case some(wi_id) ->
                  collect_feedback_set(rest, put(acc, wi_id, true))

    -- ── Annotate rows with has_feedback only ───────────────────────
    -- `unblocks` is filled in later for the (much smaller) ready
    -- partition; computing it here for every row is O(N^3) in the
    -- interpreter (each count_transitive walks up to N dependents and
    -- annotate_rows fires N times).

    operation annotate_rows(rows: List[Row],
                            fb_set: Map[String, Bool])
      -> List[Row]
    =
      match rows
        case nil() -> nil()
        case cons(r, rest) ->
          match r
            case Row(rid, status, desc, deps, _, _) ->
              cons(
                Row(
                  id: rid,
                  status: status,
                  description: desc,
                  depends: deps,
                  unblocks: 0,
                  has_feedback: contains(fb_set, rid)),
                annotate_rows(rest, fb_set))

    -- Fill in `unblocks` for the supplied rows. Each row's count uses a
    -- fresh visited set (correctness for diamond patterns); we call
    -- this only on the `ready` partition to keep the cost bounded.
    operation fill_unblocks(rows: List[Row],
                            dep_map: Map[String, List[String]])
      -> List[Row]
    =
      match rows
        case nil() -> nil()
        case cons(r, rest) ->
          match r
            case Row(rid, status, desc, deps, _, fb) ->
              match count_transitive(rid, dep_map, empty())
                case pair(n, _) ->
                  cons(
                    Row(
                      id: rid,
                      status: status,
                      description: desc,
                      depends: deps,
                      unblocks: n,
                      has_feedback: fb),
                    fill_unblocks(rest, dep_map))

    -- ── Sorting (stable merge sort, O(N log N)) ───────────────────

    -- Split a Row list into (first half, second half) preserving order,
    -- via tortoise/hare. The left half holds the strictly-earlier input
    -- positions, which — combined with a left-biased merge — makes the
    -- sort stable. Stability is required: the data has duplicate ids
    -- (WI-169) and the bundle must match the legacy stable sort.
    operation split_half(rs: List[Row]) -> Pair[List[Row], List[Row]] =
      split_half_go(rs, rs)

    operation split_half_go(slow: List[Row], fast: List[Row])
      -> Pair[List[Row], List[Row]]
    =
      match fast
        case nil() -> pair(nil(), slow)
        case cons(_, fast1) ->
          match fast1
            case nil() -> pair(nil(), slow)
            case cons(_, fast2) ->
              match slow
                case nil() -> pair(nil(), slow)  -- unreachable: fast outpaces slow
                case cons(s, slow1) ->
                  match split_half_go(slow1, fast2)
                    case pair(l, r) -> pair(cons(s, l), r)

    -- ── Chronological + topological order (WI-174) ────────────────
    -- Walk a section's rows in id order; for each not-yet-emitted row,
    -- postorder-emit its in-section, not-yet-emitted dependencies first,
    -- then the row itself. Each item thus appears after all its
    -- (in-section) dependencies, while the top-level cursor advances
    -- chronologically — the earliest item anchors a cluster of its
    -- dependencies immediately before it. Deps that live OUTSIDE this
    -- section (a different status group, or the ready/blocked
    -- counterpart) are absent from `section_map` and skipped: they are
    -- satisfied anchors, displayed under their own section. This is the
    -- general replacement for the old unblocks-count ready ordering;
    -- `unblocks` survives as display-only annotation, no longer a sort key.
    --
    -- Rows are identified by id here, exactly as `build_row_map` keys the
    -- ready/blocked classification this same command relies on. Two rows
    -- sharing BOTH id and status (which `add` precludes — ids are
    -- auto-assigned) would therefore collapse to one in this walk; the
    -- one benign historical duplicate (WI-169) carries two different
    -- statuses, so it lands in two distinct groups and both rows show.
    operation chrono_topo(rows: List[Row]) -> List[Row] =
      let sorted = sort_by_id(rows)
      let section_map = build_row_map(sorted)
      match chrono_topo_walk(sorted, section_map, empty(), nil())
        case pair(_, acc) -> reverse_rows(acc)

    operation chrono_topo_walk(rows: List[Row],
                               section_map: Map[String, Row],
                               emitted: Map[String, Bool],
                               acc: List[Row])
      -> Pair[Map[String, Bool], List[Row]]
    =
      match rows
        case nil() -> pair(emitted, acc)
        case cons(r, rest) ->
          match emit_row(r, section_map, emitted, acc)
            case pair(e2, a2) -> chrono_topo_walk(rest, section_map, e2, a2)

    -- Postorder emit of `r`: mark on entry (so a cyclic dep can't
    -- re-enter and loop), recurse into in-section deps, then prepend
    -- self. `acc` is built reversed; chrono_topo reverses at the end.
    operation emit_row(r: Row,
                       section_map: Map[String, Row],
                       emitted: Map[String, Bool],
                       acc: List[Row])
      -> Pair[Map[String, Bool], List[Row]]
    =
      match r
        case Row(rid, _, _, deps, _, _) ->
          if contains(emitted, rid) then pair(emitted, acc)
          else
            let emitted1 = put(emitted, rid, true)
            match emit_deps(deps, section_map, emitted1, acc)
              case pair(e2, a2) -> pair(e2, cons(r, a2))

    operation emit_deps(deps: List[String],
                        section_map: Map[String, Row],
                        emitted: Map[String, Bool],
                        acc: List[Row])
      -> Pair[Map[String, Bool], List[Row]]
    =
      match deps
        case nil() -> pair(emitted, acc)
        case cons(d, rest) ->
          match get(section_map, d)
            case none() -> emit_deps(rest, section_map, emitted, acc)
            case some(dep_row) ->
              match emit_row(dep_row, section_map, emitted, acc)
                case pair(e2, a2) -> emit_deps(rest, section_map, e2, a2)

    operation reverse_rows(xs: List[Row]) -> List[Row] =
      reverse_rows_acc(xs, nil())

    operation reverse_rows_acc(xs: List[Row], acc: List[Row]) -> List[Row] =
      match xs
        case nil() -> acc
        case cons(h, rest) -> reverse_rows_acc(rest, cons(h, acc))

    -- ── Status grouping (WI-174) ──────────────────────────────────
    -- Top-level grouping is by status: Open, then Claimed, then
    -- Delivered, then Verified (Verified/Delivered hidden by default via
    -- `keep`), then any other status. `ordered_present_statuses` returns
    -- exactly the statuses that occur in `filtered` (so every row lands
    -- in one group — nothing is silently dropped), ranked by lifecycle
    -- with an alphabetical tie-break for unknowns.
    -- Lifecycle order for the WorkStatus enum (domain.anthill): active
    -- queue first (Open → Claimed), then done (Delivered → Verified),
    -- then the backlog (PreOpened) and terminal off-ramps (Rejected,
    -- Stale). An unrecognised status sorts last (alphabetically among
    -- its peers via status_before's tie-break) — visible, never dropped.
    operation status_rank(status: String) -> Int64 =
      if eq(status, "Open") then 0
      else if eq(status, "Claimed") then 1
      else if eq(status, "Delivered") then 2
      else if eq(status, "Verified") then 3
      else if eq(status, "PreOpened") then 4
      else if eq(status, "Rejected") then 5
      else if eq(status, "Stale") then 6
      else 7

    operation status_before(a: String, b: String) -> Bool =
      let ra = status_rank(a)
      let rb = status_rank(b)
      if eq(ra, rb) then lt(a, b)
      else lt(ra, rb)

    operation ordered_present_statuses(rows: List[Row]) -> List[String] =
      insertion_sort_statuses(distinct_statuses(rows, nil()), nil())

    operation distinct_statuses(rows: List[Row], acc: List[String])
      -> List[String]
    =
      match rows
        case nil() -> acc
        case cons(r, rest) ->
          match r
            case Row(_, st, _, _, _, _) ->
              if list_contains_string(acc, st) then distinct_statuses(rest, acc)
              else distinct_statuses(rest, cons(st, acc))

    operation insertion_sort_statuses(xs: List[String], sorted: List[String])
      -> List[String]
    =
      match xs
        case nil() -> sorted
        case cons(x, rest) ->
          insertion_sort_statuses(rest, insert_status(x, sorted))

    operation insert_status(x: String, sorted: List[String]) -> List[String] =
      match sorted
        case nil() -> cons(x, nil())
        case cons(h, rest) ->
          if status_before(x, h) then cons(x, cons(h, rest))
          else cons(h, insert_status(x, rest))

    operation rows_with_status(rows: List[Row], status: String) -> List[Row] =
      match rows
        case nil() -> nil()
        case cons(r, rest) ->
          match r
            case Row(_, st, _, _, _, _) ->
              if eq(st, status) then cons(r, rows_with_status(rest, status))
              else rows_with_status(rest, status)

    -- Stable merge sort by id. Ties retain input order (legacy
    -- slice::sort_by is stable; the data has duplicate WI-169 ids).
    operation merge_by_id(xs: List[Row], ys: List[Row]) -> List[Row] =
      match xs
        case nil() -> ys
        case cons(x, xrest) ->
          match ys
            case nil() -> xs
            case cons(y, yrest) ->
              match x
                case Row(xid, _, _, _, _, _) ->
                  match y
                    case Row(yid, _, _, _, _, _) ->
                      if lt(yid, xid) then cons(y, merge_by_id(xs, yrest))
                      else cons(x, merge_by_id(xrest, ys))

    operation sort_by_id(rs: List[Row]) -> List[Row] =
      match rs
        case nil() -> nil()
        case cons(_, rest) ->
          match rest
            case nil() -> rs
            case cons(_, _) ->
              match split_half(rs)
                case pair(left, right) ->
                  merge_by_id(sort_by_id(left), sort_by_id(right))

    -- ── Partition into ready / blocked ────────────────────────────

    operation partition_ready(rows: List[Row],
                               row_map: Map[String, Row])
      -> List[Row]
    =
      match rows
        case nil() -> nil()
        case cons(r, rest) ->
          match r
            case Row(_, _, _, deps, _, _) ->
              if any_unmet(deps, row_map) then partition_ready(rest, row_map)
              else cons(r, partition_ready(rest, row_map))

    operation partition_blocked(rows: List[Row],
                                 row_map: Map[String, Row])
      -> List[Row]
    =
      match rows
        case nil() -> nil()
        case cons(r, rest) ->
          match r
            case Row(_, _, _, deps, _, _) ->
              if any_unmet(deps, row_map) then cons(r, partition_blocked(rest, row_map))
              else partition_blocked(rest, row_map)

    -- ── Print ─────────────────────────────────────────────────────

    operation deps_suffix(deps: List[String]) -> String =
      match deps
        case nil() -> ""
        case cons(_, _) ->
          concat(" (depends: ", concat(join_strings(deps, ", "), ")"))

    operation unblocks_suffix(n: Int64) -> String =
      if eq(n, 0) then ""
      else concat(" [unblocks ", concat(to_string(n), "]"))

    operation feedback_suffix(b: Bool) -> String =
      if b then " [has feedback]" else ""

    operation render_ready(r: Row) -> String =
      match r
        case Row(id, status, desc, deps, n, fb) ->
          concat("  ",
            concat(id, concat(" [", concat(status, concat("] ",
              concat(desc,
                concat(deps_suffix(deps),
                  concat(unblocks_suffix(n), feedback_suffix(fb))))))) ))

    operation render_blocked(r: Row) -> String =
      match r
        case Row(id, status, desc, deps, _, fb) ->
          concat("  ",
            concat(id, concat(" [", concat(status, concat("] ",
              concat(desc, concat(deps_suffix(deps), feedback_suffix(fb))))))))

    operation print_rows_ready(rs: List[Row]) -> Unit
      effects ConsoleOutput
    =
      match rs
        case nil() -> ()
        case cons(r, rest) ->
          let _ = println(console(), render_ready(r))
          print_rows_ready(rest)

    operation print_rows_blocked(rs: List[Row]) -> Unit
      effects ConsoleOutput
    =
      match rs
        case nil() -> ()
        case cons(r, rest) ->
          let _ = println(console(), render_blocked(r))
          print_rows_blocked(rest)

    operation count_rows(rs: List[Row]) -> Int64 =
      match rs
        case nil() -> 0
        case cons(_, rest) -> 1 + count_rows(rest)

    -- Print each status group in turn (WI-174). `first` suppresses the
    -- leading blank-line separator for the very first group. Every status
    -- in `statuses` is present in `filtered`, so each group is non-empty
    -- and always prints a header.
    operation print_groups(statuses: List[String],
                           filtered: List[Row],
                           row_map: Map[String, Row],
                           dep_map: Map[String, List[String]],
                           first: Bool) -> Unit
      effects ConsoleOutput
    =
      match statuses
        case nil() -> ()
        case cons(st, rest) ->
          let group = rows_with_status(filtered, st)
          let _ = if first then () else println(console(), "")
          let _ = println(console(), concat(st, ":"))
          let _ = print_group_body(group, row_map, dep_map)
          print_groups(rest, filtered, row_map, dep_map, false)

    -- One status group's body: ready then (if any) the `-- blocked --`
    -- section, each ordered chrono+topo. `unblocks` is filled only on the
    -- ready slice (display-only; the blocked render omits it).
    operation print_group_body(group: List[Row],
                               row_map: Map[String, Row],
                               dep_map: Map[String, List[String]]) -> Unit
      effects ConsoleOutput
    =
      let ready = chrono_topo(fill_unblocks(partition_ready(group, row_map), dep_map))
      let blocked = chrono_topo(partition_blocked(group, row_map))
      let _ = print_rows_ready(ready)
      match blocked
        case nil() -> ()
        case cons(_, _) ->
          let _ = match ready
            case nil() -> ()
            case cons(_, _) -> println(console(), "")
          let _ = println(console(), "  -- blocked --")
          print_rows_blocked(blocked)

    -- ── cmd_list itself ───────────────────────────────────────────

    operation cmd_list(args: List[Binding], s: Cell[State]) -> Int64
      effects {ConsoleOutput, Error}
    =
      match get_arg(args, "tag")
        case some(t) -> cmd_list_tagged(s, t, get_arg(args, "status"))
        case none() -> cmd_list_plain(args, s)

    operation cmd_list_plain(args: List[Binding], s: Cell[State]) -> Int64
      effects {ConsoleOutput, Error}
    =
      let status_filter = get_arg(args, "status")
      let show_all = match get_arg(args, "all")
        case some(_) -> true
        case none() -> false
      let raw_rows = rows_of_w(WorkItemStore.all(s))
      let dep_map = build_dep_map(raw_rows)
      let fb_set = feedback_set()
      let annotated = annotate_rows(raw_rows, fb_set)
      let row_map = build_row_map(annotated)
      let filtered = filter_rows(annotated, status_filter, show_all)
      if eq(count_rows(filtered), 0) then
        let _ = println(console(), "No work items found.")
        0
      else
        -- WI-174: group by status (Open → Claimed → Delivered → …); each
        -- group splits into ready / blocked, each section ordered
        -- chrono+topo (chrono_topo). `row_map` spans ALL rows so the
        -- ready/blocked split sees deps that live in other groups.
        let statuses = ordered_present_statuses(filtered)
        let _ = print_groups(statuses, filtered, row_map, dep_map, true)
        let _ = println(console(),
                        concat(to_string(count_rows(filtered)), " item(s)"))
        0

    -- ── cmd_list --tag (the named-list sequence view) ─────────────
    -- Items in dependency (topological) order; the first undelivered
    -- item whose deps are all satisfied is marked `<- next`; unmet deps
    -- show `(blocked: …)`. Mirrors the native run_list_tagged: Kahn
    -- with smallest-id tie-break over edges "b transitively depends on
    -- a" (reach goes THROUGH untagged intermediates), a tag pointing at
    -- a missing id prints `[missing]` (a data error stays visible), and
    -- the status filter is applied per row AFTER ordering.
    operation cmd_list_tagged(s: Cell[State], tag_name: String,
                              status_filter: Option[String]) -> Int64
      effects {ConsoleOutput, Error}
    =
      let ids = sort_strings_unique(WorkItemStore.items_with_tag(s, tag_name))
      match ids
        case nil() ->
          let _ = println(console(),
            concat("No work items tagged '", concat(tag_name, "'.")))
          0
        case cons(_, _) ->
          let row_map = build_row_map(rows_of_w(WorkItemStore.all(s)))
          let ordered = topo_order_tagged(row_map, ids)
          let _ = println(console(),
            concat("tag '", concat(tag_name,
              concat("' (", concat(to_string(count_strings(ordered)),
                " item(s), sequence order):")))))
          let shown = print_tagged_rows(ordered, row_map, status_filter,
                                        false, 0)
          let _ = println(console(), concat(to_string(shown), " item(s)"))
          0

    -- Kahn's algorithm with the smallest-id tie-break: `pending` is
    -- kept id-sorted, so the first pending id that depends on no OTHER
    -- pending id is exactly the minimal ready node. A cycle leaves no
    -- ready node — the remainder is appended in id order rather than
    -- silently dropped (the native fallback).
    operation topo_order_tagged(row_map: Map[String, Row],
                                pending: List[String]) -> List[String] =
      match find_ready(row_map, pending, pending)
        case none() -> pending
        case some(n) ->
          cons(n, topo_order_tagged(row_map, remove_string(pending, n)))

    operation find_ready(row_map: Map[String, Row], scan: List[String],
                         pending: List[String]) -> Option[T = String] =
      match scan
        case nil() -> none()
        case cons(n, rest) ->
          if reaches_any_other(row_map, n, pending) then
            find_ready(row_map, rest, pending)
          else some(n)

    operation reaches_any_other(row_map: Map[String, Row], n: String,
                                pending: List[String]) -> Bool =
      match pending
        case nil() -> false
        case cons(m, rest) ->
          if eq(m, n) then reaches_any_other(row_map, n, rest)
          else if row_reaches(row_map, n, m, nil()) then true
          else reaches_any_other(row_map, n, rest)

    -- True when `from` transitively depends on `target`, walking through
    -- ALL items (tagged or not). `seen` guards re-visits so a corrupt
    -- cyclic store can't hang the view.
    operation row_reaches(row_map: Map[String, Row], from: String,
                          target: String, seen: List[String]) -> Bool =
      if list_contains_string(seen, from) then false
      else
        match get(row_map, from)
          case none() -> false
          case some(r) ->
            match r
              case Row(_, _, _, deps, _, _) ->
                row_deps_reach(row_map, deps, target, cons(from, seen))

    operation row_deps_reach(row_map: Map[String, Row], deps: List[String],
                             target: String, seen: List[String]) -> Bool =
      match deps
        case nil() -> false
        case cons(d, rest) ->
          if eq(d, target) then true
          else if row_reaches(row_map, d, target, seen) then true
          else row_deps_reach(row_map, rest, target, seen)

    operation print_tagged_rows(ids: List[String],
                                row_map: Map[String, Row],
                                status_filter: Option[String],
                                next_marked: Bool, shown: Int64) -> Int64
      effects ConsoleOutput
    =
      match ids
        case nil() -> shown
        case cons(id, rest) ->
          match get(row_map, id)
            case none() ->
              let _ = println(console(),
                concat("  ", concat(id, " [missing] (no such work item)")))
              print_tagged_rows(rest, row_map, status_filter,
                                next_marked, shown + 1)
            case some(r) ->
              match r
                case Row(_, status, desc, deps, _, _) ->
                  let pass = match status_filter
                    case none() -> true
                    case some(f) -> matches_filter(status, f)
                  if pass then
                    let unmet = unmet_deps(deps, row_map)
                    let is_next =
                      if next_marked then false
                      else if is_satisfied(status) then false
                      else match unmet
                        case nil() -> true
                        case cons(_, _) -> false
                    let blocked = match unmet
                      case nil() -> ""
                      case cons(_, _) ->
                        concat(" (blocked: ",
                          concat(join_strings(unmet, ", "), ")"))
                    let marker = if is_next then "  <- next" else ""
                    let marked_after = if is_next then true else next_marked
                    let _ = println(console(),
                      concat("  ", concat(id,
                        concat(" [", concat(status,
                          concat("] ", concat(truncate_desc(desc),
                            concat(blocked, marker))))))))
                    print_tagged_rows(rest, row_map, status_filter,
                                      marked_after, shown + 1)
                  else
                    print_tagged_rows(rest, row_map, status_filter,
                                      next_marked, shown)

    -- Deps not yet Delivered/Verified. A dep id with no row counts as
    -- unmet — a dangling reference must stay visible, never read as met.
    operation unmet_deps(deps: List[String],
                         row_map: Map[String, Row]) -> List[String] =
      match deps
        case nil() -> nil()
        case cons(d, rest) ->
          match get(row_map, d)
            case none() -> cons(d, unmet_deps(rest, row_map))
            case some(r) ->
              match r
                case Row(_, st, _, _, _, _) ->
                  if is_satisfied(st) then unmet_deps(rest, row_map)
                  else cons(d, unmet_deps(rest, row_map))

    -- First 100 chars + '…' (native truncate_desc(s, 100); substring /
    -- length are char-based builtins, so multibyte text truncates
    -- identically to the native chars() walk).
    operation truncate_desc(s: String) -> String =
      if lt(length(s), 101) then s
      else concat(substring(s, 0, 100), "…")

    -- Insertion sort, ascending, dropping duplicates (the native view
    -- collects tag members into a set before ordering).
    operation sort_strings_unique(xs: List[String]) -> List[String] =
      match xs
        case nil() -> nil()
        case cons(x, rest) -> insert_string_sorted(sort_strings_unique(rest), x)

    operation insert_string_sorted(xs: List[String], x: String) -> List[String] =
      match xs
        case nil() -> cons(x, nil())
        case cons(h, rest) ->
          if eq(x, h) then xs
          else if lt(x, h) then cons(x, xs)
          else cons(h, insert_string_sorted(rest, x))

    operation count_strings(xs: List[String]) -> Int64 =
      match xs
        case nil() -> 0
        case cons(_, rest) -> 1 + count_strings(rest)

    -- ── cmd_graph ─────────────────────────────────────────────────

    -- Find rows whose depends_on list is empty (roots of the dependents
    -- tree — no precondition).
    operation find_roots(rows: List[Row]) -> List[Row] =
      match rows
        case nil() -> nil()
        case cons(r, rest) ->
          match r
            case Row(_, _, _, deps, _, _) ->
              match deps
                case nil() -> cons(r, find_roots(rest))
                case cons(_, _) -> find_roots(rest)

    operation status_or_unknown(row_map: Map[String, Row], id: String) -> String =
      match status_for_m(row_map, id)
        case some(s) -> s
        case none() -> "?"

    -- Print one node and recurse into its direct dependents. Mirrors
    -- legacy `print_tree` exactly: connector is "" at the root, "├─ "
    -- for non-last siblings, "└─ " for last; child_prefix continues
    -- with "│  " or "   " depending on whether `is_last` was true.
    operation print_tree(id: String,
                         is_root: Bool,
                         is_last: Bool,
                         prefix: String,
                         row_map: Map[String, Row],
                         dep_map: Map[String, List[String]])
      -> Unit
      effects ConsoleOutput
    =
      let connector =
        if is_root then ""
        else if is_last then "└─ "
        else "├─ "
      let status = status_or_unknown(row_map, id)
      let _ = println(console(),
                      concat(prefix,
                        concat(connector,
                          concat(id, concat(" [", concat(status, "]"))))))
      let child_prefix =
        if is_root then "   "
        else if is_last then concat(prefix, "   ")
        else concat(prefix, "│  ")
      let children = direct_dependents_m(dep_map, id)
      print_children(children, child_prefix, row_map, dep_map)

    operation print_children(children: List[String],
                             prefix: String,
                             row_map: Map[String, Row],
                             dep_map: Map[String, List[String]])
      -> Unit
      effects ConsoleOutput
    =
      match children
        case nil() -> ()
        case cons(c, rest) ->
          let last = match rest
            case nil() -> true
            case cons(_, _) -> false
          let _ = print_tree(c, false, last, prefix, row_map, dep_map)
          print_children(rest, prefix, row_map, dep_map)

    operation print_roots(roots: List[Row],
                          row_map: Map[String, Row],
                          dep_map: Map[String, List[String]])
      -> Unit
      effects ConsoleOutput
    =
      match roots
        case nil() -> ()
        case cons(r, rest) ->
          match r
            case Row(rid, _, _, _, _, _) ->
              let _ = print_tree(rid, true, true, "", row_map, dep_map)
              print_roots(rest, row_map, dep_map)

    operation cmd_graph(s: Cell[State]) -> Int64
      effects {ConsoleOutput, Error}
    =
      let raw_rows = rows_of_w(WorkItemStore.all(s))
      if eq(count_rows(raw_rows), 0) then
        let _ = println(console(), "No work items found.")
        0
      else
        let dep_map = build_dep_map(raw_rows)
        let row_map = build_row_map(raw_rows)
        let roots = find_roots(raw_rows)
        let _ = print_roots(roots, row_map, dep_map)
        0

    -- ── cmd_add ──────────────────────────────────────────────────
    --
    -- `add <description> [--depends ID]* [--acceptance tool]*`
    -- creates a fresh WorkItem with status Open. The next id is
    -- computed by walking existing WorkItem facts and bumping the
    -- max WI-NNN suffix. Acceptance defaults to ToolPasses("cargo-test")
    -- when no --acceptance flag is supplied.

    -- Collect every Binding whose name matches `name`, in caller order.
    -- parse_argv conses args front-most-recent, so the last flag the
    -- user typed appears first in the input list. Walking that list and
    -- consing into `acc` flips each time, leaving acc in caller order on
    -- exit. Used by cmd_add for repeatable flags (--depends, --acceptance).
    operation collect_all_args_acc(args: List[Binding],
                                        name: String,
                                        acc: List[String]) -> List[String] =
      match args
        case nil() -> acc
        case cons(b, rest) ->
          match b
            case Binding(bname, bvalue) ->
              if eq(bname, name) then
                collect_all_args_acc(rest, name, cons(bvalue, acc))
              else
                collect_all_args_acc(rest, name, acc)

    operation collect_all_args(args: List[Binding],
                                    name: String) -> List[String] =
      collect_all_args_acc(args, name, nil())

    -- Wrap each tool name as ToolPasses(tool: <name>) for the WorkItem
    -- acceptance field. Default fallback when the user supplies no
    -- --acceptance flag is a single cargo-test entry.
    operation tool_to_acceptance(tool: String) -> AcceptanceCriterion =
      ToolPasses(tool: tool)

    operation tools_to_acceptance(tools: List[String])
      -> List[AcceptanceCriterion]
    =
      match tools
        case nil() -> nil()
        case cons(h, rest) ->
          cons(tool_to_acceptance(h), tools_to_acceptance(rest))

    operation cmd_add(args: List[Binding],
                      store: FileStore,
                      s: Cell[State]) -> Int64
      effects {ConsoleOutput, ConsoleError, Modify[s], Error}
    =
      match get_arg(args, "description")
        case none() ->
          let _ = eprintln(console(), "add: missing description")
          2
        case some(description) ->
          do_add(s, description,
                 collect_all_args(args, "depends"),
                 collect_all_args(args, "acceptance"),
                 collect_all_args(args, "tag"))

    operation do_add(s: Cell[State], description: String,
                     depends_on: List[String],
                     raw_acceptance: List[String],
                     tags: List[String]) -> Int64
      effects {ConsoleOutput, Modify[s], Error}
    =
      let id = WorkItemStore.next_id(s)
      let _ = WorkItemStore.commit(s, WorkItem(
        id: id,
        description: description,
        acceptance: resolve_acceptance(raw_acceptance),
        depends_on: depends_on,
        status: Open()))
      let _ = apply_tags(s, id, tags)
      let _ = println(console(),
                      concat("added: ",
                        concat(id, concat(" — ",
                          concat(description, tag_note(tags))))))
      0

    -- ` [tags: a, b]` suffix on add/insert output; empty for no tags.
    operation tag_note(tags: List[String]) -> String =
      match tags
        case nil() -> ""
        case cons(_, _) ->
          concat(" [tags: ", concat(join_strings(tags, ", "), "]"))

    -- Persist one Tag fact per name (a fresh item can't carry
    -- duplicates, so no already-tagged check here).
    operation apply_tags(s: Cell[State], id: String, tags: List[String]) -> Unit
      effects {Modify[s], Error}
    =
      match tags
        case nil() -> ()
        case cons(t, rest) ->
          let _ = WorkItemStore.tag_item(s, id, t)
          apply_tags(s, id, rest)

    -- ── cmd_insert ───────────────────────────────────────────────
    -- `insert <description> --before <id> [--tag t]* [--depends d]*
    -- [--acceptance a]*` — create the item, tag it, and make the
    -- --before target depend on it (the build loop's "insert
    -- prerequisite"). Mirrors the native run_insert: the --before
    -- target must exist, and a --depends that is (or transitively
    -- reaches) the target is a cycle and rejected loudly.
    operation cmd_insert(args: List[Binding], s: Cell[State]) -> Int64
      effects {ConsoleOutput, ConsoleError, Modify[s], Error}
    =
      match get_arg(args, "description")
        case none() ->
          let _ = eprintln(console(), "insert: missing description")
          2
        case some(description) ->
          match get_arg(args, "before")
            case none() ->
              let _ = eprintln(console(), "insert: missing --before")
              2
            case some(before) ->
              match WorkItemStore.lookup(s, before)
                case none() ->
                  let _ = eprintln(console(),
                    concat("error: --before target '",
                      concat(before, "' not found")))
                  1
                case some(before_wi) ->
                  do_insert(s, description, before, before_wi,
                            collect_all_args(args, "tag"),
                            collect_all_args(args, "depends"),
                            collect_all_args(args, "acceptance"))

    operation do_insert(s: Cell[State], description: String,
                        before: String, before_wi: WorkItem,
                        tags: List[String],
                        depends_on: List[String],
                        raw_acceptance: List[String]) -> Int64
      effects {ConsoleOutput, ConsoleError, Modify[s], Error}
    =
      match first_cycle_dep(s, depends_on, before)
        case some(d) ->
          let _ = eprintln(console(),
            concat("error: inserting before ",
              concat(before, concat(" with dependency ",
                concat(d, " would create a cycle")))))
          1
        case none() ->
          -- Native ordering: allocate the id and rewrite the --before
          -- target's depends_on FIRST, so a failing rewrite can't leave
          -- an orphaned, unlinked item behind.
          let id = WorkItemStore.next_id(s)
          let current = deps_of_w(before_wi)
          let new_deps =
            if list_contains_string(current, id) then current
            else append_string(current, id)
          let _ = WorkItemStore.replace(s, before,
                    with_deps(before_wi, new_deps))
          let _ = WorkItemStore.commit(s, WorkItem(
            id: id,
            description: description,
            acceptance: resolve_acceptance(raw_acceptance),
            depends_on: depends_on,
            status: Open()))
          let _ = apply_tags(s, id, tags)
          let _ = println(console(),
            concat("inserted: ",
              concat(id, concat(" before ",
                concat(before, concat(tag_note(tags),
                  concat(" (", concat(before,
                    concat(" now depends on ",
                      concat(id, ")"))))))))))
          0

    -- The first --depends entry that equals the --before target or
    -- transitively reaches it (closing a cycle once the target depends
    -- on the new item); none() when the insert is safe.
    operation first_cycle_dep(s: Cell[State], deps: List[String],
                              before: String) -> Option[T = String]
      effects Error
    =
      match deps
        case nil() -> none()
        case cons(d, rest) ->
          if eq(d, before) then some(d)
          else if reaches_dep(s, d, before, nil()) then some(d)
          else first_cycle_dep(s, rest, before)

    -- True when `from` transitively depends on `target`. `seen` guards
    -- against re-visiting (a corrupt cyclic store must not hang the CLI).
    operation reaches_dep(s: Cell[State], from: String, target: String,
                          seen: List[String]) -> Bool
      effects Error
    =
      if list_contains_string(seen, from) then false
      else
        match WorkItemStore.lookup(s, from)
          case none() -> false
          case some(wi) ->
            any_dep_reaches(s, deps_of_w(wi), target, cons(from, seen))

    operation any_dep_reaches(s: Cell[State], deps: List[String],
                              target: String, seen: List[String]) -> Bool
      effects Error
    =
      match deps
        case nil() -> false
        case cons(d, rest) ->
          if eq(d, target) then true
          else if reaches_dep(s, d, target, seen) then true
          else any_dep_reaches(s, rest, target, seen)

    -- Default acceptance to a single `cargo-test` tool when no
    -- --acceptance flag is supplied; otherwise lift each tool name.
    operation resolve_acceptance(raw: List[String]) -> List[AcceptanceCriterion] =
      match raw
        case nil() -> tools_to_acceptance(cons("cargo-test", nil()))
        case cons(_, _) -> tools_to_acceptance(raw)

    -- Reconstruct a WorkItem with a new status field, preserving every
    -- other field as the materialized entity carried them. Factored as
    -- an op (not a let-bound expression) to dodge a typer env-loss bug
    -- where a let-bound constructor's TypeResult.env drops the
    -- enclosing-sort context and downstream spec-op dispatch fails to
    -- find the requires-chain slot. Pattern-match on positional fields
    -- in declared order (id, description, context, acceptance,
    -- depends_on, generates, requires_capability, status).
    operation with_status(wi: WorkItem, st: WorkStatus) -> WorkItem =
      match wi
        case WorkItem(id, desc, ctx, acc, deps, gen, reqs, _) ->
          WorkItem(
            id: id,
            description: desc,
            context: ctx,
            acceptance: acc,
            depends_on: deps,
            generates: gen,
            requires_capability: reqs,
            status: st)

    operation with_description(wi: WorkItem, new_desc: String) -> WorkItem =
      match wi
        case WorkItem(id, _, ctx, acc, deps, gen, reqs, st) ->
          WorkItem(
            id: id,
            description: new_desc,
            context: ctx,
            acceptance: acc,
            depends_on: deps,
            generates: gen,
            requires_capability: reqs,
            status: st)

    operation with_acceptance(wi: WorkItem,
                              new_acc: List[AcceptanceCriterion])
      -> WorkItem
    =
      match wi
        case WorkItem(id, desc, ctx, _, deps, gen, reqs, st) ->
          WorkItem(
            id: id,
            description: desc,
            context: ctx,
            acceptance: new_acc,
            depends_on: deps,
            generates: gen,
            requires_capability: reqs,
            status: st)

    operation with_deps(wi: WorkItem, new_deps: List[String]) -> WorkItem =
      match wi
        case WorkItem(id, desc, ctx, acc, _, gen, reqs, st) ->
          WorkItem(
            id: id,
            description: desc,
            context: ctx,
            acceptance: acc,
            depends_on: new_deps,
            generates: gen,
            requires_capability: reqs,
            status: st)

    -- ── cmd_claim ────────────────────────────────────────────────
    -- `claim <id>` transitions Open → Claimed(agent, since). Routes
    -- through WorkItemStore.lookup → replace, which buffers the
    -- retract+persist pair and flushes once (atomic update: a mid-step
    -- failure on the Error effect leaves nothing written).

    operation cmd_claim(args: List[Binding],
                         store: FileStore,
                         agent: String,
                         s: Cell[State]) -> Int64
      effects {ConsoleOutput, ConsoleError, Modify[s], Error, Clock}
    =
      match get_arg(args, "id")
        case none() ->
          let _ = eprintln(console(), "claim: missing id")
          2
        case some(id) ->
          match WorkItemStore.lookup(s, id)
            case none() ->
              let _ = eprintln(console(),
                concat("error: work item '", concat(id, "' not found")))
              1
            case some(wi) -> do_claim(s, agent, id, wi)

    operation do_claim(s: Cell[State], agent: String,
                       id: String, wi: WorkItem) -> Int64
      effects {ConsoleOutput, Modify[s], Error, Clock}
    =
      let _ = WorkItemStore.replace(s, id,
        with_status(wi, Claimed(agent: agent, since: now())))
      let _ = println(console(),
        concat("claimed: ", concat(id, concat(" by ", agent))))
      0

    -- ── cmd_unclaim ──────────────────────────────────────────────
    -- `unclaim <id>`: Claimed → Open, the inverse of `claim`. Only
    -- valid from Claimed — any other status is an error (there is no
    -- claim to release), so a typo or a double-unclaim fails loudly
    -- rather than silently no-op'ing. Replacing the whole status with
    -- Open() clears the agent/since the Claimed status carried. Honors
    -- --agent only for the audit line (Open carries no claimant).
    operation cmd_unclaim(args: List[Binding],
                           store: FileStore,
                           agent: String,
                           s: Cell[State]) -> Int64
      effects {ConsoleOutput, ConsoleError, Modify[s], Error}
    =
      match get_arg(args, "id")
        case none() ->
          let _ = eprintln(console(), "unclaim: missing id")
          2
        case some(id) ->
          match WorkItemStore.lookup(s, id)
            case none() ->
              let _ = eprintln(console(),
                concat("error: work item '", concat(id, "' not found")))
              1
            case some(wi) -> do_unclaim(s, agent, id, wi)

    operation do_unclaim(s: Cell[State], agent: String,
                         id: String, wi: WorkItem) -> Int64
      effects {ConsoleOutput, ConsoleError, Modify[s], Error}
    =
      let st = status_name_w(wi)
      if eq(st, "Claimed") then
        let _ = WorkItemStore.replace(s, id, with_status(wi, Open()))
        let _ = println(console(),
          concat("unclaimed: ", concat(id, concat(" by ", agent))))
        0
      else
        let _ = eprintln(console(),
          concat("error: work item '",
            concat(id, concat("' is not claimed (status: ",
              concat(st, "); nothing to release")))))
        1

    -- ── cmd_deliver ──────────────────────────────────────────────
    -- `deliver <id>`: Claimed → Delivered(agent, at).

    operation cmd_deliver(args: List[Binding],
                           store: FileStore,
                           agent: String,
                           s: Cell[State]) -> Int64
      effects {ConsoleOutput, ConsoleError, Modify[s], Error, Clock}
    =
      match get_arg(args, "id")
        case none() ->
          let _ = eprintln(console(), "deliver: missing id")
          2
        case some(id) ->
          match WorkItemStore.lookup(s, id)
            case none() ->
              let _ = eprintln(console(),
                concat("error: work item '", concat(id, "' not found")))
              1
            case some(wi) -> do_deliver(s, agent, id, wi)

    operation do_deliver(s: Cell[State], agent: String,
                         id: String, wi: WorkItem) -> Int64
      effects {ConsoleOutput, Modify[s], Error, Clock}
    =
      let _ = WorkItemStore.replace(s, id,
        with_status(wi, Delivered(agent: agent, at: now())))
      let _ = println(console(),
        concat("delivered: ", concat(id, concat(" by ", agent))))
      0

    -- ── cmd_verify ───────────────────────────────────────────────
    -- `verify <id>`: Delivered → Verified(at). No agent — the verifier
    -- identity isn't recorded in the legacy fact shape.

    operation cmd_verify(args: List[Binding],
                          store: FileStore,
                          s: Cell[State]) -> Int64
      effects {ConsoleOutput, ConsoleError, Modify[s], Error, Clock}
    =
      match get_arg(args, "id")
        case none() ->
          let _ = eprintln(console(), "verify: missing id")
          2
        case some(id) ->
          match WorkItemStore.lookup(s, id)
            case none() ->
              let _ = eprintln(console(),
                concat("error: work item '", concat(id, "' not found")))
              1
            case some(wi) -> do_verify(s, id, wi)

    operation do_verify(s: Cell[State], id: String, wi: WorkItem) -> Int64
      effects {ConsoleOutput, Modify[s], Error, Clock}
    =
      let _ = WorkItemStore.replace(s, id, with_status(wi, Verified(at: now())))
      let _ = println(console(), concat("verified: ", id))
      0

    -- ── cmd_delete ───────────────────────────────────────────────
    -- `delete <id>` retracts the WorkItem fact entirely (no
    -- replacement). The impl's forget routes through find_fact +
    -- retract so the IndexedFileStore drops the on-disk block.

    operation cmd_delete(args: List[Binding],
                          store: FileStore,
                          s: Cell[State]) -> Int64
      effects {ConsoleOutput, ConsoleError, Modify[s], Error}
    =
      match get_arg(args, "id")
        case none() ->
          let _ = eprintln(console(), "delete: missing id")
          2
        case some(id) ->
          match WorkItemStore.lookup(s, id)
            case none() ->
              let _ = eprintln(console(),
                concat("error: work item '", concat(id, "' not found")))
              1
            case some(_) ->
              let _ = WorkItemStore.forget(s, id)
              let _ = println(console(), concat("deleted: ", id))
              0

    -- ── cmd_update ───────────────────────────────────────────────
    -- `update <id> [--description X] [--acceptance Y]+` rewrites a
    -- work item's description and/or acceptance criteria. Passing
    -- --acceptance at least once replaces the entire acceptance list
    -- (no append mode — matches legacy run_update).
    operation cmd_update(args: List[Binding],
                          store: FileStore,
                          s: Cell[State]) -> Int64
      effects {ConsoleOutput, ConsoleError, Modify[s], Error}
    =
      match get_arg(args, "id")
        case none() ->
          let _ = eprintln(console(), "update: missing id")
          2
        case some(id) ->
          match WorkItemStore.lookup(s, id)
            case none() ->
              let _ = eprintln(console(),
                concat("error: work item '", concat(id, "' not found")))
              1
            case some(wi) ->
              let new_desc = get_arg(args, "description")
              let raw_acc = collect_all_args(args, "acceptance")
              do_update(s, id, wi, new_desc, raw_acc)

    operation do_update(s: Cell[State], id: String, wi: WorkItem,
                        new_desc: Option[String],
                        raw_acc: List[String]) -> Int64
      effects {ConsoleOutput, ConsoleError, Modify[s], Error}
    =
      let has_desc = opt_string_present(new_desc)
      let has_acc = match raw_acc
        case nil() -> false
        case cons(_, _) -> true
      if not(has_desc) then
        if not(has_acc) then
          let _ = eprintln(console(),
            "update: nothing to change — pass --description and/or --acceptance")
          2
        else
          let _ = WorkItemStore.replace(s, id,
            with_acceptance(wi, tools_to_acceptance(raw_acc)))
          let _ = println(console(),
            concat("updated ", concat(id, ": acceptance")))
          0
      else
        let new_wi = update_fields(wi, new_desc, has_acc, raw_acc)
        let _ = WorkItemStore.replace(s, id, new_wi)
        let summary = if has_acc then "description, acceptance" else "description"
        let _ = println(console(), concat("updated ",
          concat(id, concat(": ", summary))))
        0

    operation opt_string_present(o: Option[String]) -> Bool =
      match o
        case none() -> false
        case some(_) -> true

    operation unwrap_string(o: Option[String]) -> String =
      match o
        case some(s) -> s
        case none() -> ""

    operation update_fields(wi: WorkItem,
                             new_desc: Option[String],
                             has_acc: Bool,
                             raw_acc: List[String]) -> WorkItem =
      let wi_d = with_description(wi, unwrap_string(new_desc))
      if has_acc then with_acceptance(wi_d, tools_to_acceptance(raw_acc))
      else wi_d

    -- ── cmd_add_dependency ───────────────────────────────────────
    -- `add-dependency <id> <dep>` appends dep to id's depends_on
    -- list. Validates self-loop and target-exists; rejects already-a-dep.
    -- Cycle detection deferred (filed as follow-up).
    operation cmd_add_dependency(args: List[Binding],
                                  store: FileStore,
                                  s: Cell[State]) -> Int64
      effects {ConsoleOutput, ConsoleError, Modify[s], Error}
    =
      match get_arg(args, "id")
        case none() ->
          let _ = eprintln(console(), "add-dependency: missing id")
          2
        case some(id) ->
          match get_arg(args, "dep")
            case none() ->
              let _ = eprintln(console(),
                "add-dependency: missing dep id")
              2
            case some(dep) ->
              if eq(id, dep) then
                let _ = eprintln(console(),
                  "error: work item cannot depend on itself")
                1
              else
                match WorkItemStore.lookup(s, id)
                  case none() ->
                    let _ = eprintln(console(),
                      concat("error: work item '",
                        concat(id, "' not found")))
                    1
                  case some(wi) ->
                    match WorkItemStore.lookup(s, dep)
                      case none() ->
                        let _ = eprintln(console(),
                          concat("error: dependency target '",
                            concat(dep, "' not found")))
                        1
                      case some(_) -> do_add_dep(s, id, dep, wi)

    operation do_add_dep(s: Cell[State], id: String, dep: String,
                          wi: WorkItem) -> Int64
      effects {ConsoleOutput, ConsoleError, Modify[s], Error}
    =
      let current = deps_of_w(wi)
      if list_contains_string(current, dep) then
        let _ = eprintln(console(),
          concat("error: '", concat(id,
            concat("' already depends on '", concat(dep, "'")))))
        1
      -- Cycle guard (the legacy run_add_dependency check): adding
      -- id -> dep closes a cycle iff dep already transitively
      -- depends on id.
      else if reaches_dep(s, dep, id, nil()) then
        let _ = eprintln(console(),
          concat("error: adding ", concat(id,
            concat(" -> ", concat(dep,
              concat(" would create a cycle (", concat(dep,
                concat(" already transitively depends on ",
                  concat(id, ")")))))))))
        1
      else
        let _ = WorkItemStore.replace(s, id,
          with_deps(wi, append_string(current, dep)))
        let _ = println(console(),
          concat("added dependency: ",
            concat(id, concat(" -> ", dep))))
        0

    -- ── cmd_remove_dependency ────────────────────────────────────
    -- `remove-dependency <id> <dep>` filters dep out of id's
    -- depends_on. Errors if dep isn't currently a dependency.
    operation cmd_remove_dependency(args: List[Binding],
                                     store: FileStore,
                                     s: Cell[State]) -> Int64
      effects {ConsoleOutput, ConsoleError, Modify[s], Error}
    =
      match get_arg(args, "id")
        case none() ->
          let _ = eprintln(console(), "remove-dependency: missing id")
          2
        case some(id) ->
          match get_arg(args, "dep")
            case none() ->
              let _ = eprintln(console(),
                "remove-dependency: missing dep id")
              2
            case some(dep) ->
              match WorkItemStore.lookup(s, id)
                case none() ->
                  let _ = eprintln(console(),
                    concat("error: work item '",
                      concat(id, "' not found")))
                  1
                case some(wi) -> do_remove_dep(s, id, dep, wi)

    operation do_remove_dep(s: Cell[State], id: String, dep: String,
                             wi: WorkItem) -> Int64
      effects {ConsoleOutput, ConsoleError, Modify[s], Error}
    =
      let current = deps_of_w(wi)
      if list_contains_string(current, dep) then
        let _ = WorkItemStore.replace(s, id,
          with_deps(wi, remove_string(current, dep)))
        let _ = println(console(),
          concat("removed dependency: ",
            concat(id, concat(" -> ", dep))))
        0
      else
        let _ = eprintln(console(),
          concat("error: '", concat(id,
            concat("' does not depend on '", concat(dep, "'")))))
        1

    -- Filter `target` out of a String list (preserves remaining order).
    operation remove_string(xs: List[String], target: String)
      -> List[String]
    =
      match xs
        case nil() -> nil()
        case cons(h, rest) ->
          if eq(h, target) then remove_string(rest, target)
          else cons(h, remove_string(rest, target))

    -- ── cmd_feedback ─────────────────────────────────────────────
    --
    -- `feedback <id> <text>` asserts a Feedback fact through
    -- WorkItemStore.commit_feedback. Output mirrors legacy
    -- run_feedback's `feedback on <id>: <text>` line.
    operation cmd_feedback(args: List[Binding],
                            store: FileStore,
                            agent: String,
                            s: Cell[State]) -> Int64
      effects {ConsoleOutput, ConsoleError, Modify[s], Error, Clock}
    =
      let id_opt = get_arg(args, "id")
      let text_opt = get_arg(args, "text")
      match id_opt
        case none() ->
          let _ = eprintln(console(), "feedback: missing id")
          2
        case some(id) ->
          match text_opt
            case none() ->
              let _ = eprintln(console(), "feedback: missing text")
              2
            case some(text) ->
              do_feedback(s, agent, id, text)

    operation do_feedback(s: Cell[State], agent: String,
                          id: String, text: String) -> Int64
      effects {ConsoleOutput, Modify[s], Error, Clock}
    =
      let _ = WorkItemStore.commit_feedback(s, Feedback(
        workitem: id,
        author: agent,
        content: text,
        at: now()))
      let _ = println(console(),
                      concat("feedback on ",
                        concat(id, concat(": ", text))))
      0

    -- ── cmd_next ─────────────────────────────────────────────────
    --
    -- Show the next claimable work item: items in status Open whose
    -- dependencies are all Delivered/Verified. With --all, every such
    -- item; otherwise just the first. WI-182 unblocks this — the
    -- `fresh_var` and `make_fn` builtins let anthill code construct
    -- the goal `claimable(?id, ?desc)` and run it via `KB.execute`.

    -- Pull a String binding off a substitution by var name; return
    -- `fallback` when missing or when the bound term isn't a String
    -- literal (e.g. a synthetic entity declaration's logical-var
    -- field).
    operation extract_string_field(subst: Substitution,
                                   var_name: String,
                                   fallback: String) -> String =
      match Substitution.lookup(subst, var_name)
        case none() -> fallback
        case some(t) ->
          match term_as_string(t)
            case none() -> fallback
            case some(s) -> s

    -- Single-pass stream walk: pull one solution at a time, dedupe by id
    -- against a running `seen` accumulator, print as we go. Tail-style
    -- recursion: every recursive call is the last expression in its
    -- branch, so the deepest stack is bounded by `limit` (1000). No
    -- intermediate list — `append_pair`-style quadratic build was the
    -- cause of the stack overflow on real workitem sets.
    -- WI-385: `execute` returns the ABSTRACT `Stream[Substitution, Error]`;
    -- this consumer only uses `splitFirst` (a Stream primitive), so it takes the
    -- producer's type. The value is a `LogicalStream` at runtime (which provides
    -- Stream), so `splitFirst` dispatches to it. Declaring the param as the
    -- concrete `LogicalStream` was a latent over-narrowing (a Stream-vs-LogicalStream
    -- downcast) the discarded arg-unify masked before arg validation.
    operation walk_solutions(stream: Stream[T = Substitution, E = Error],
                              show_all: Bool,
                              limit: Int64,
                              seen: List[String],
                              printed: Int64) -> Int64
      effects {ConsoleOutput, Error}
    =
      if eq(limit, 0) then printed
      else
        -- QUALIFIED dispatch (WI-411): the bare `splitFirst(stream)` on an
        -- abstract Stream receiver self-dispatches and dies at eval with
        -- "unknown operation: splitFirst"; Stream.splitFirst routes through
        -- the spec and reaches the runtime LogicalStream impl.
        match Stream.splitFirst(stream)
          case none() -> printed
          case some(p) ->
            match p
              case pair(subst, rest) ->
                let id = extract_string_field(subst, "id", "?")
                let desc = extract_string_field(subst, "desc", "")
                if list_contains_string(seen, id) then
                  walk_solutions(rest, show_all, limit + (0 - 1), seen, printed)
                else
                  let _ = println(console(),
                                  concat("  ",
                                    concat(id, concat(" — ", desc))))
                  if show_all then
                    walk_solutions(rest, show_all,
                                   limit + (0 - 1),
                                   cons(id, seen),
                                   printed + 1)
                  else
                    printed + 1

    operation list_contains_string(xs: List[String], needle: String) -> Bool =
      match xs
        case nil() -> false
        case cons(h, rest) ->
          if eq(h, needle) then true
          else list_contains_string(rest, needle)


    operation cmd_next(args: List[Binding], s: Cell[State]) -> Int64
      effects {ConsoleOutput, ConsoleError, Error}
    =
      let show_all = match get_arg(args, "all")
        case some(_) -> true
        case none() -> false
      let id_var = fresh_var[Term]("id")
      let desc_var = fresh_var[Term]("desc")
      let goal = make_fn("anthill.stage0.workflow.claimable",
                         cons(id_var, cons(desc_var, nil())))
      let stream = execute(kb(), pattern_query(term: goal))
      let printed = walk_solutions(stream, show_all, 1000, nil(), 0)
      if eq(printed, 0) then
        let _ = println(console(), "No claimable items (all blocked or none open).")
        0
      else 0
  end
end
