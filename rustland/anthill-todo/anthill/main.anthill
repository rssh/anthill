-- anthill-todo: structured work-item management.
--
-- This is the anthill side of the rust+anthill realization (WI-164,
-- proposal 029). The companion Rust shim at src/main.rs embeds these
-- .anthill files via include_str!, builds a KB, registers stdlib
-- builtins + persistence handlers + a project-local FileStore, then
-- calls `anthill.todo.Main.main(args)` and forwards its `Int` return
-- value as the process exit code.
--
-- Phase 1 (WI-009): minimum-viable dispatcher with --skill and
-- placeholder responses for the read-only commands. Mutating
-- subcommands and the full subcommand catalogue land in later phases.
namespace anthill.todo
  import anthill.cli.Main
  import anthill.prelude.{List}
  import anthill.prelude.List.{nil, cons}
  import anthill.prelude.Console.{console, println, eprintln,
                                  ConsoleOutput, ConsoleError}
  import anthill.cli.parse.{parse_argv, ParseResult, ParsedArgs,
                            parse_ok, parse_err,
                            no_subcommand, unknown_subcommand}
  import anthill.cli.spec.{OperationSpec}
  import anthill.prelude.Option.{none}
  export Main, specs

  -- Subcommand registry. Phase 1a: skill only — full catalogue
  -- (status, list, show, graph, next, init, add, feedback, claim,
  -- deliver, verify, update, add-dependency, remove-dependency,
  -- delete) lands in later phases.
  operation specs() -> List[T = OperationSpec] =
    cons(OperationSpec(
           name: "skill",
           description: "Print Claude Code skill definition to stdout",
           params: nil(),
           parent: none()),
         nil())

  sort Main
    requires anthill.cli.Main

    operation main(args: List[T = String]) -> Int
      effects {ConsoleOutput, ConsoleError}
    =
      match parse_argv(specs(), args)
        case parse_err(no_subcommand()) ->
          let _ = eprintln(console(), "anthill-todo: no subcommand (try `skill`)")
          1
        case parse_err(unknown_subcommand(given)) ->
          let _ = eprintln(console(),
            "anthill-todo: unknown subcommand")
          2
        case parse_err(_) ->
          let _ = eprintln(console(), "anthill-todo: argument error")
          2
        case parse_ok(ParsedArgs(name, _)) ->
          dispatch(name)

    operation dispatch(name: String) -> Int
      effects ConsoleOutput
    =
      let _ = println(console(),
        "anthill-todo (WI-009 phase 1a): subcommand received")
      0
  end
end
