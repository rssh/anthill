-- C++ binding for anthill.prelude.Int. Proposal 038 — host-specific
-- spec satisfaction lives separately from the language-agnostic spec
-- in stdlib/anthill/prelude/int.anthill.
namespace anthill.prelude
  provides Int language cpp
    artifact "rustland/anthill-cpp-gen/src/lib.rs"
    carrier Int = "int64_t"
    fact Eq[T = Int]
    fact Ordered[T = Int]
    fact Numeric[T = Int]
  end
end
