namespace my.args
  import anthill.cli.Main
  import anthill.prelude.Console.{console, println, ConsoleOutput}
  import anthill.prelude.{Int64, String, List}
  export Argv

  sort Argv
    requires anthill.cli.Main

    operation print_each(args: List[T = String]) -> Int64
      effects ConsoleOutput
    =
      match args
        case cons(h, rest) ->
          let _ = println(console(), h)
          print_each(rest)
        case nil() -> 0

    operation main(args: List[T = String]) -> Int64
      effects ConsoleOutput
    = print_each(args)
  end
end
