fact WorkItem(id: "WI-029", description: "De Bruijn variable representation: DeBruijn(u32) for bound vars in stored terms, Global(VarId) for instantiated vars during resolution. Enables canonical hash-consing, per-query caching, and proper quantifier scoping. See Proposal 024. Prerequisite for WI-027 (forall in rule bodies).", context: ?context, acceptance: cons(head: ToolPasses("cargo-test", tool: ?tool, params: ?params), tail: nil), depends_on: nil, generates: ?generates, requires_capability: ?requires_capability, status: Claimed(agent: "claude", since: "2026-03-26T12:03:10Z"))
