-- Persistence: abstract storage algebra (proposal 007 Â§2 â€” trait/policy model)
--
-- Capability comes in two kinds, two mechanisms:
--   * PROVISION â€” a trait carrying an operation. `retract` / `retrieve` / `pull`
--     are not on every store, so having one = providing its trait. An
--     append-only backend simply does not provide `NonMonotonicStore` and has
--     no `retract` at all.
--   * POLICY â€” a per-predicate value over universal ops. `persist` is on every
--     Store, but whether it (and `retract`) is permitted for a functor is that
--     functor's `monotonicity` (proposal 053), answered by `monotonicity`.
--
-- The sorts:
--   Store              â€” base: persist, flush, monotonicity (all backends)
--   NonMonotonicStore  â€” adds retract (mutation capability; e.g. filesystem, SQL)
--   QueryableStore     â€” adds retrieve (pattern-based query; e.g. SQL)
--   BulkStore          â€” adds pull (load all into memory; e.g. filesystem)
namespace anthill.persistence
  import anthill.reflect.{Term, FactId, Symbol, Monotonicity}
  import anthill.prelude.{List, Stream}
  import anthill.prelude.Meta.{Meta}

  -- ================================================================
  -- Store: base storage backend
  -- ================================================================

  sort Store {
    -- Persist a fact to its backing store. Permitted iff the fact's functor
    -- is not `constant` (proposal 053).
    operation persist(store: Store, fact: Term, meta: Meta) -> FactId
      effects {Modify[store], Error}

    -- Flush KB delta (new/changed/retracted facts) back to store
    operation flush(store: Store, delta: List[T = Term]) -> Bool
      effects {Modify[store], Error}

    -- Write POLICY (proposal 053) of a functor this store owns: which write
    -- operations are permitted for it â€” constant (none), monotone (persist
    -- only), non_monotone (persist + retract). A QUERY: the system reads it to
    -- plan (persist iff != constant, retract iff non_monotone), NEVER by
    -- attempting a write and catching the failure.
    operation monotonicity(store: Store, functor: Symbol) -> Monotonicity
  }

  -- Given a fact, which store owns it?
  operation route(fact: Term) -> Store

  -- ================================================================
  -- NonMonotonicStore: mutation capability (proposal 053 / 007 Â§2)
  -- ================================================================

  -- Mutation is a capability: only a NonMonotonicStore carries `retract`. A
  -- store that does not provide this trait cannot be asked to retract at all,
  -- so its `monotonicity` answers can only be `monotone` or `constant` â€”
  -- `non_monotone` implies this trait (the consistency is structural, not a
  -- separate capability bound).
  sort NonMonotonicStore {
    fact Store                                -- NonMonotonicStore is-a Store

    -- Remove a fact from its backing store. Permitted iff the functor is
    -- `non_monotone` (proposal 053). A backend that cannot honor a declared
    -- non_monotone retract fails loudly at the write via the Error effect,
    -- not a static load check.
    operation retract(store: NonMonotonicStore, id: FactId) -> Bool
      effects {Modify[store], Error}
  }

  -- ================================================================
  -- QueryableStore: pattern-based retrieval
  -- ================================================================

  sort QueryableStore {
    fact Store                                -- QueryableStore is-a Store

    -- Retrieve facts matching a pattern (delegates to backend query).
    -- Streamed rather than materialized so a queryable backend can yield
    -- 1M rows without forcing them all into memory at once. Concrete
    -- backends surface rows via `StreamSource::External` (proposal 026.1
    -- Q4 + 007 Â§11) so each row enters Ïƒ as `Value::Entity` without
    -- `TermStore` allocation. A caller that genuinely wants a fully
    -- materialized list must drain this bare (maybe-infinite) `Stream`
    -- with a BOUNDED `takeN(retrieve(...), n)` â€” the unbounded eager
    -- `collect` moved to `FiniteCollection` (proposal library/003, Phase C /
    -- WI-589) and does NOT apply to a plain query `Stream`, which carries no
    -- finiteness guarantee.
    operation retrieve(store: QueryableStore, pattern: Term) -> Stream[Term, Error]
      effects Error
  }

  -- ================================================================
  -- BulkStore: load-all-into-memory
  -- ================================================================

  sort BulkStore {
    fact Store                                -- BulkStore is-a Store

    -- Pull all facts from store into the KB
    operation pull(store: BulkStore) -> List[T = Term]
      effects Error
  }

end
