fact WorkItem(
  id: "WI-346",
  description: "Warn when a requires-reached operation is shadowed: when a sort 'requires' a spec and declares a local operation whose short name shadows an inherited same-named operation, emit a warning ('operation X shadows the required A.X'). Implements the shadow-warning prescribed in docs/kernel-language.md §8.7 'Operation override' (override is the provides direction; a requires-user's same-named op is unrelated). Scaffold test: rustland/anthill-core/tests/include/wi210_dispatch_test.rs::requires_user_with_same_named_op_does_not_provide_or_override pins the distinct-symbol behavior; add the warning assertion once the channel exists.",
  acceptance: [ToolPasses("cargo-test")],
  depends_on: ["WI-345"],
  status: Delivered(agent: "claude", at: "2026-06-01T18:48:41Z"))

